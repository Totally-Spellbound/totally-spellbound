{% comment %}
  Spellbound Product Extras
  Static section rendered after product-information.
  Shows correspondences (metafield properties) as a definition grid card
  plus a special "Handmade by Totally Spellbound" badge.
{% endcomment %}

<style>
  .spellbound-product-extras {
    position: relative;
    z-index: 1;
    padding: clamp(2rem, 6vw, 4rem) 1.5rem 2rem;
    max-width: var(--narrow-page-width, 90rem);
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .spellbound-product-extras {
      padding-inline: var(--padding-lg, 2rem);
    }
  }

  /* Faint zodiac-chart atmosphere behind the correspondences card,
     melting into the page background at top and bottom */
  .spellbound-extras-atmos {
    position: absolute;
    left: 0;
    right: 0;
    height: 480px;
    margin-top: -120px;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 22%, black 78%, transparent);
    mask-image: linear-gradient(to bottom, transparent, black 22%, black 78%, transparent);
  }
  .spellbound-extras-atmos img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.13;
    filter: brightness(0.9) saturate(0.85);
  }

  /* Correspondences card */
  .spellbound-extras__card {
    background: var(--spellbound-surface);
    border: 1px solid var(--spellbound-border);
    border-radius: 10px;
    padding: 2rem;
    margin-top: 1rem;
  }
  @media (min-width: 1024px) {
    .spellbound-extras__card { padding: 2.5rem; }
  }

  .spellbound-extras__title {
    font-family: var(--spellbound-type-display-family);
    font-weight: 400;
    color: var(--spellbound-text);
    font-size: var(--spellbound-type-section-title-size);
    line-height: var(--spellbound-leading-heading);
    margin: 0 0 var(--spellbound-space-8);
  }

  /* Handmade badge */
  .spellbound-extras__handmade {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--spellbound-gold-bright);
    background: var(--spellbound-gold-glow);
    border: 1px solid var(--spellbound-gold-deep);
    border-radius: 999px;
    padding: 0.5rem 1rem;
    margin-bottom: 2rem;
  }
  .spellbound-extras__handmade svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* Definition grid */
  .spellbound-extras__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem 2rem;
  }
  @media (min-width: 640px) {
    .spellbound-extras__grid { grid-template-columns: 1fr 1fr; }
  }
  .spellbound-extras__key {
    display: block;
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 12px;
    color: var(--spellbound-gold);
    text-transform: uppercase;
    letter-spacing: 0.28em;
    margin-bottom: 0.5rem;
  }
  .spellbound-extras__val {
    color: var(--spellbound-text);
    font-size: 0.9375rem;
    letter-spacing: 0.04em;
    line-height: 1.5;
  }
</style>

{%- assign current_product = product -%}

{%- capture planet_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.planet -%}{%- endcapture -%}
{%- capture element_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.element -%}{%- endcapture -%}
{%- capture zodiac_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.zodiac -%}{%- endcapture -%}
{%- capture chakra_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.chakra -%}{%- endcapture -%}
{%- capture crystal_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.crystal_type -%}{%- endcapture -%}
{%- capture intention_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.intention -%}{%- endcapture -%}
{%- capture theme_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.theme -%}{%- endcapture -%}
{%- assign handmade = current_product.metafields.custom.handmade -%}

{%- assign planet_clean = planet_clean | strip -%}
{%- assign element_clean = element_clean | strip -%}
{%- assign zodiac_clean = zodiac_clean | strip -%}
{%- assign chakra_clean = chakra_clean | strip -%}
{%- assign crystal_clean = crystal_clean | strip -%}
{%- assign intention_clean = intention_clean | strip -%}
{%- assign theme_clean = theme_clean | strip -%}

{%- assign has_any_meta = false -%}
{%- if planet_clean != blank or element_clean != blank or zodiac_clean != blank or chakra_clean != blank or crystal_clean != blank or intention_clean != blank or theme_clean != blank -%}
  {%- assign has_any_meta = true -%}
{%- endif -%}

{% if has_any_meta or handmade %}
<div class="spellbound-extras-atmos" aria-hidden="true">
  <img
    src="{{ 'spellbound-img-zodiac.jpg' | asset_url }}"
    alt=""
    loading="lazy"
    width="968"
    height="516"
  >
</div>
<div class="spellbound-product-extras" data-spellbound-reveal>
  <div class="spellbound-extras__card">
    <h2 class="spellbound-extras__title">Correspondences</h2>

    {% if handmade %}
      <div class="spellbound-extras__handmade">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 4.9 5.4.8-3.9 3.8.9 5.4L12 14.8 7.2 17l.9-5.4L4.2 7.7l5.4-.8z"/></svg>
        Handmade by Totally Spellbound
      </div>
    {% endif %}

    {% if has_any_meta %}
      <div class="spellbound-extras__grid">
        {% if crystal_clean != blank %}
          <div>
            <span class="spellbound-extras__key">Crystal</span>
            <div class="spellbound-extras__val">{{ crystal_clean }}</div>
          </div>
        {% endif %}
        {% if planet_clean != blank %}
          <div>
            <span class="spellbound-extras__key">Primary Planet</span>
            <div class="spellbound-extras__val">{{ planet_clean }}</div>
          </div>
        {% endif %}
        {% if element_clean != blank %}
          <div>
            <span class="spellbound-extras__key">Ruling Element</span>
            <div class="spellbound-extras__val">{{ element_clean }}</div>
          </div>
        {% endif %}
        {% if zodiac_clean != blank %}
          <div>
            <span class="spellbound-extras__key">Zodiac Sign</span>
            <div class="spellbound-extras__val">{{ zodiac_clean }}</div>
          </div>
        {% endif %}
        {% if chakra_clean != blank %}
          <div>
            <span class="spellbound-extras__key">Chakra</span>
            <div class="spellbound-extras__val">{{ chakra_clean }}</div>
          </div>
        {% endif %}
        {% if intention_clean != blank %}
          <div>
            <span class="spellbound-extras__key">Intention</span>
            <div class="spellbound-extras__val">{{ intention_clean }}</div>
          </div>
        {% endif %}
        {% if theme_clean != blank %}
          <div>
            <span class="spellbound-extras__key">Theme</span>
            <div class="spellbound-extras__val">{{ theme_clean }}</div>
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>
{% else %}
<div class="spellbound-product-extras" data-spellbound-reveal>
  <div class="spellbound-extras__card spellbound-extras__card--fallback">
    <h2 class="spellbound-extras__title">From the Shop Floor</h2>
    <p class="spellbound-extras__fallback-lead">
      Wondering if this piece is right for you? Ask us - we answer like we would
      over the counter.
    </p>
    <p class="spellbound-extras__fallback-copy">
      Totally Spellbound is a real independent shop in Sutton-in-Ashfield, not a
      faceless warehouse. If you want to know more about this piece - what it is,
      where it's from, how to care for it - message us or pop in, and Alison will
      point you to the right piece, never the expensive one.
    </p>
    <div class="spellbound-extras__fallback-points">
      <span>&#10022; Independent family shop</span>
      <span>&#10022; Free UK delivery over &pound;50</span>
      <span>&#10022; Free click &amp; collect</span>
    </div>
    <div class="spellbound-extras__fallback-actions">
      <a href="/pages/contact" class="spellbound-extras__fallback-btn">Ask About This Piece</a>
      <a href="/pages/visit-us" class="spellbound-extras__fallback-btn spellbound-extras__fallback-btn--ghost">Visit the Shop</a>
    </div>

    {%- liquid
      assign xsell_col = blank
      for c in product.collections
        if c.handle != 'all' and c.all_products_count > 1
          assign xsell_col = c
          break
        endif
      endfor
      if xsell_col == blank
        assign xsell_col = collections['all']
      endif
    -%}
    {%- if xsell_col != blank and xsell_col.products.size > 1 -%}
      <div class="spellbound-extras__xsell">
        <h3 class="spellbound-extras__xsell-title">
          {%- if xsell_col.handle == 'all' -%}More From The Vault{%- else -%}More from {{ xsell_col.title | escape }}{%- endif -%}
        </h3>
        <div class="spellbound-extras__xsell-grid">
          {%- assign shown = 0 -%}
          {%- for xp in xsell_col.products limit: 8 -%}
            {%- if xp.id != product.id and shown < 4 -%}
              {%- assign shown = shown | plus: 1 -%}
              <a href="{{ xp.url }}" class="spellbound-extras__xsell-card">
                <span class="spellbound-extras__xsell-media">
                  {%- if xp.featured_image -%}
                    <img
                      src="{{ xp.featured_image | image_url: width: 400 }}"
                      alt="{{ xp.featured_image.alt | default: xp.title | escape }}"
                      loading="lazy"
                      width="{{ xp.featured_image.width }}"
                      height="{{ xp.featured_image.height }}"
                    >
                  {%- endif -%}
                </span>
                <span class="spellbound-extras__xsell-name">{{ xp.title | escape }}</span>
                <span class="spellbound-extras__xsell-price">{{ xp.price | money }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>
{% endif %}

<style>
  .spellbound-extras__card--fallback {
    text-align: center;
  }
  .spellbound-extras__fallback-lead {
    font-family: var(--font-accent--family);
    font-style: italic;
    font-size: clamp(1.25rem, 2vw, 1.5rem);
    line-height: 1.5;
    color: var(--spellbound-text);
    margin: 1rem auto 1rem;
    max-width: 48rem;
  }
  .spellbound-extras__fallback-copy {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: var(--spellbound-text-soft);
    margin: 0 auto 1.75rem;
    max-width: 44rem;
  }
  .spellbound-extras__fallback-points {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem 2rem;
    font-size: 0.9375rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--spellbound-gold);
    margin-bottom: 2rem;
  }
  .spellbound-extras__fallback-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
  }
  .spellbound-extras__fallback-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.95rem 2.2rem;
    border-radius: 999px;
    background: var(--spellbound-gold);
    border: 1px solid var(--spellbound-gold);
    color: var(--spellbound-bg);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }
  .spellbound-extras__fallback-btn:hover {
    background: var(--spellbound-gold-bright);
    border-color: var(--spellbound-gold-bright);
  }
  .spellbound-extras__fallback-btn--ghost {
    background: transparent;
    color: var(--spellbound-text);
    border-color: var(--spellbound-border-strong);
  }
  .spellbound-extras__fallback-btn--ghost:hover {
    background: transparent;
    color: var(--spellbound-gold);
    border-color: var(--spellbound-gold);
  }
  .spellbound-extras__xsell {
    margin-top: 3rem;
    padding-top: 2.25rem;
    border-top: 1px solid var(--spellbound-border);
  }
  .spellbound-extras__xsell-title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 1.25rem;
    color: var(--spellbound-text);
    margin: 0 0 1.5rem;
  }
  .spellbound-extras__xsell-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem 1rem;
    text-align: left;
  }
  @media (min-width: 750px) {
    .spellbound-extras__xsell-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  .spellbound-extras__xsell-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
  }
  .spellbound-extras__xsell-media {
    display: block;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 10px;
    border: 1px solid var(--spellbound-border);
    background: var(--spellbound-surface);
  }
  .spellbound-extras__xsell-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-extras__xsell-card:hover .spellbound-extras__xsell-media img {
    transform: scale(1.04);
  }
  .spellbound-extras__xsell-name {
    font-family: var(--spellbound-type-reading-family);
    font-size: var(--spellbound-type-product-title-size);
    font-weight: 600;
    line-height: var(--spellbound-leading-product-title);
    color: var(--spellbound-text);
  }
  .spellbound-extras__xsell-card:hover .spellbound-extras__xsell-name {
    color: var(--spellbound-gold-bright);
  }
  .spellbound-extras__xsell-price {
    font-family: var(--spellbound-type-reading-family);
    font-size: var(--spellbound-type-price-size);
    font-weight: 600;
    line-height: var(--spellbound-leading-interface);
    color: var(--spellbound-text);
  }
</style>

{% schema %}
{
  "name": "Spellbound Extras",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [],
  "presets": [
    {
      "name": "Spellbound Extras"
    }
  ]
}
{% endschema %}
