{% comment %}
  Spellbound Product Extras
  Injects into the Horizon product-information section via JS:
  - "THEME • HANDMADE" amber label above title
  - "← RETURN TO VAULT" back link above media
  - "IN STOCK" indicator next to price
  - Italic quote styling for description
  - Wishlist "Mark in Grimoire" button after add-to-cart
  - Metafield properties grid below buy buttons
  - Element badge overlay on product image
{% endcomment %}

<style>
  .spellbound-product-extras__source { display: none; }

  /* Back link */
  .spellbound-back-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: color 0.3s ease;
    margin-bottom: 3rem;
  }
  .spellbound-back-link:hover { color: #ffffff; }
  .spellbound-back-link svg { flex-shrink: 0; }

  /* Theme + handmade label */
  .spellbound-theme-label {
    color: #f59e0b;
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: block;
  }

  /* Price row with IN STOCK */
  .spellbound-price-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .spellbound-price-row__divider {
    height: 1px;
    flex: 1;
    background: rgba(255,255,255,0.1);
  }
  .spellbound-price-row__stock {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #34d399;
    flex-shrink: 0;
  }
  .spellbound-price-row__stock--out {
    color: #ef4444;
  }

  /* Grimoire (wishlist) button */
  .spellbound-grimoire-btn {
    width: 100%;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    color: rgba(255,255,255,0.4);
    padding: 1.25rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    font-size: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 1rem;
  }
  .spellbound-grimoire-btn:hover {
    color: #ffffff;
    border-color: rgba(255,255,255,0.2);
  }
  .spellbound-grimoire-btn--active {
    color: #fde68a;
    border-color: rgba(253,230,138,0.3);
  }
  .spellbound-grimoire-btn svg { transition: fill 0.3s ease; }

  /* Metafield properties grid */
  .spellbound-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 2.5rem;
    margin-top: 2.5rem;
  }
  .spellbound-meta-grid__label {
    display: block;
    font-size: 8px;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    margin-bottom: 0.5rem;
  }
  .spellbound-meta-grid__value {
    color: #ffffff;
    font-size: 0.875rem;
    letter-spacing: 0.15em;
    border-left: 1px solid rgba(255,255,255,0.2);
    padding-left: 1rem;
  }

  /* Element badge overlay on product image */
  .spellbound-image-badge {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    z-index: 5;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .spellbound-image-badge__tag {
    font-size: 8px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    padding: 4px 8px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.8);
    width: fit-content;
  }

  /* Description italic quote styling */
  .product-information .product-details .rte p,
  .product-information .product-details [data-block-type="text"] .rte p {
    font-style: italic;
    color: rgba(255,255,255,0.4);
    font-size: 0.875rem;
    line-height: 1.6;
  }
</style>

{%- assign current_product = product -%}
{%- if current_product == blank -%}{%- break -%}{%- endif -%}

{%- capture planet_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.planet -%}{%- endcapture -%}
{%- capture element_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.element -%}{%- endcapture -%}
{%- capture zodiac_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.zodiac -%}{%- endcapture -%}
{%- capture chakra_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.chakra -%}{%- endcapture -%}
{%- capture crystal_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.crystal_type -%}{%- endcapture -%}
{%- capture intention_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.intention -%}{%- endcapture -%}
{%- capture theme_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.theme -%}{%- endcapture -%}
{%- assign handmade = current_product.metafields.custom.handmade -%}

{%- assign planet_clean = planet_clean | strip -%}
{%- assign element_clean = element_clean | strip -%}
{%- assign zodiac_clean = zodiac_clean | strip -%}
{%- assign chakra_clean = chakra_clean | strip -%}
{%- assign crystal_clean = crystal_clean | strip -%}
{%- assign intention_clean = intention_clean | strip -%}
{%- assign theme_clean = theme_clean | strip -%}

<div class="spellbound-product-extras__source" id="spellbound-product-extras-data">

  <!-- Back link -->
  <div id="spellbound-back-link-wrapper">
    <a href="{{ collection.url | default: routes.all_products_collection_url }}" class="spellbound-back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Return to Vault
    </a>
  </div>

  <!-- Theme + Handmade label -->
  {% if theme_clean != blank or handmade %}
  <div id="spellbound-theme-label-wrapper">
    <span class="spellbound-theme-label">
      {%- if theme_clean != blank -%}{{ theme_clean }}{%- endif -%}
      {%- if theme_clean != blank and handmade %} &bull; {% endif -%}
      {%- if handmade -%}Handmade{%- endif -%}
    </span>
  </div>
  {% endif %}

  <!-- Price row stock indicator -->
  <div id="spellbound-stock-indicator">
    <div class="spellbound-price-row__divider"></div>
    {% if current_product.available %}
      <span class="spellbound-price-row__stock">In Stock</span>
    {% else %}
      <span class="spellbound-price-row__stock spellbound-price-row__stock--out">Sold Out</span>
    {% endif %}
  </div>

  <!-- Element badge for product image -->
  {% if element_clean != blank %}
  <div id="spellbound-image-badge-wrapper">
    <div class="spellbound-image-badge">
      <span class="spellbound-image-badge__tag">{{ element_clean }}</span>
    </div>
  </div>
  {% endif %}

  <!-- Wishlist button -->
  <div id="spellbound-grimoire-wrapper">
    <button class="spellbound-grimoire-btn" data-product-id="{{ current_product.id }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      <span class="spellbound-grimoire-btn__label">Mark in Grimoire</span>
    </button>
  </div>

  <!-- Metafield properties grid -->
  {% if planet_clean != blank or element_clean != blank or zodiac_clean != blank or chakra_clean != blank or crystal_clean != blank or intention_clean != blank or theme_clean != blank or handmade %}
  <div id="spellbound-meta-grid-wrapper">
    <div class="spellbound-meta-grid">
      {% if planet_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Primary Planet</span>
          <div class="spellbound-meta-grid__value">{{ planet_clean }}</div>
        </div>
      {% endif %}
      {% if element_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Ruling Element</span>
          <div class="spellbound-meta-grid__value">{{ element_clean }}</div>
        </div>
      {% endif %}
      {% if zodiac_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Zodiac Sign</span>
          <div class="spellbound-meta-grid__value">{{ zodiac_clean }}</div>
        </div>
      {% endif %}
      {% if chakra_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Chakra</span>
          <div class="spellbound-meta-grid__value">{{ chakra_clean }}</div>
        </div>
      {% endif %}
      {% if crystal_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Crystal</span>
          <div class="spellbound-meta-grid__value">{{ crystal_clean }}</div>
        </div>
      {% endif %}
      {% if intention_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Intention</span>
          <div class="spellbound-meta-grid__value">{{ intention_clean }}</div>
        </div>
      {% endif %}
      {% if theme_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Theme</span>
          <div class="spellbound-meta-grid__value">{{ theme_clean }}</div>
        </div>
      {% endif %}
      {% if handmade %}
        <div>
          <span class="spellbound-meta-grid__label">Craft</span>
          <div class="spellbound-meta-grid__value">Handmade</div>
        </div>
      {% endif %}
    </div>
  </div>
  {% endif %}
</div>

<script src="{{ 'spellbound-wishlist.js' | asset_url }}" defer></script>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var source = document.getElementById('spellbound-product-extras-data');
    if (!source) return;

    // === 1. Back link above media ===
    var mediaCol = document.querySelector('.product-information__media');
    var backLink = document.getElementById('spellbound-back-link-wrapper');
    if (mediaCol && backLink) {
      mediaCol.style.position = 'relative';
      mediaCol.insertBefore(backLink, mediaCol.firstChild);
      backLink.style.display = 'block';
    }

    // === 2. Theme label above title ===
    var detailsCol = document.querySelector('.product-details');
    var themeLabel = document.getElementById('spellbound-theme-label-wrapper');
    if (detailsCol && themeLabel) {
      // Insert before the first child of the details column
      detailsCol.insertBefore(themeLabel, detailsCol.firstChild);
      themeLabel.style.display = 'block';
    }

    // === 3. Stock indicator next to price ===
    var stockIndicator = document.getElementById('spellbound-stock-indicator');
    // Find the price block inside product details
    var priceBlock = detailsCol ? detailsCol.querySelector('[data-block-type="price"], .price') : null;
    if (!priceBlock && detailsCol) {
      // Try finding price via heading group
      var allBlocks = detailsCol.querySelectorAll('[data-block-type]');
      allBlocks.forEach(function(b) {
        if (b.querySelector('.price') || b.querySelector('[data-block-type="price"]')) {
          priceBlock = b;
        }
      });
    }
    if (!priceBlock) {
      // Broader search: find the price element anywhere in product-information
      var priceEl = document.querySelector('.product-information .price');
      if (priceEl) priceBlock = priceEl.closest('[data-block-type]') || priceEl.parentElement;
    }
    if (priceBlock && stockIndicator) {
      // Make the price container flex so stock sits on the right
      priceBlock.style.display = 'flex';
      priceBlock.style.alignItems = 'center';
      priceBlock.style.gap = '1rem';
      priceBlock.style.width = '100%';
      priceBlock.appendChild(stockIndicator);
      stockIndicator.style.display = 'flex';
      stockIndicator.style.alignItems = 'center';
      stockIndicator.style.gap = '1rem';
      stockIndicator.style.flex = '1';
    }

    // === 4. Element badge on product image ===
    var imageBadge = document.getElementById('spellbound-image-badge-wrapper');
    if (mediaCol && imageBadge) {
      // Find the first image container / gallery
      var gallery = mediaCol.querySelector('[data-block-type="_product-media-gallery"], .product-gallery, .product-media-gallery');
      var target = gallery || mediaCol;
      target.style.position = 'relative';
      target.appendChild(imageBadge);
      imageBadge.style.display = 'block';
      imageBadge.style.position = 'absolute';
      imageBadge.style.top = '0';
      imageBadge.style.left = '0';
      imageBadge.style.zIndex = '5';
    }

    // === 5. Grimoire button + meta grid inside product-details ===
    var grimoireWrapper = document.getElementById('spellbound-grimoire-wrapper');
    var metaWrapper = document.getElementById('spellbound-meta-grid-wrapper');

    // Find the add-to-cart form inside product-details
    var addToCartForm = detailsCol ? detailsCol.querySelector('form button[type="submit"]') : null;
    var formParent = addToCartForm ? addToCartForm.closest('form') : null;

    // Insertion target: after the form, or at end of product-details
    var insertTarget = formParent || (detailsCol ? detailsCol.lastElementChild : null);

    if (insertTarget && grimoireWrapper) {
      insertTarget.parentNode.insertBefore(grimoireWrapper, insertTarget.nextSibling);
      grimoireWrapper.style.display = 'block';
    }

    if (metaWrapper) {
      var metaInsertAfter = grimoireWrapper && grimoireWrapper.parentNode === insertTarget?.parentNode ? grimoireWrapper : insertTarget;
      if (metaInsertAfter) {
        metaInsertAfter.parentNode.insertBefore(metaWrapper, metaInsertAfter.nextSibling);
        metaWrapper.style.display = 'block';
      }
    }

    // === 7. Wrap description text in quotes ===
    if (detailsCol) {
      var descriptionTexts = detailsCol.querySelectorAll('.rte p');
      descriptionTexts.forEach(function(p) {
        var text = p.textContent.trim();
        if (text && !text.startsWith('"') && !text.startsWith('\u201C')) {
          p.textContent = '\u201C' + text + '\u201D';
        }
      });
    }

    // Clean up source container
    source.style.display = 'none';
  });
</script>

{% schema %}
{
  "name": "Spellbound Extras",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [],
  "templates": ["product"],
  "presets": [
    {
      "name": "Spellbound Extras"
    }
  ]
}
{% endschema %}
