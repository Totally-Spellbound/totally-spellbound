{% comment %}
  Spellbound Product Extras
  Static section rendered after product-information.
  Shows theme/handmade label and metafield properties grid.
{% endcomment %}

<style>
  /* Theme + handmade label */
  .spellbound-theme-label {
    color: #f59e0b;
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    display: block;
  }

  /* Metafield properties grid */
  .spellbound-meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 2.5rem;
    margin-top: 1rem;
  }
  .spellbound-meta-grid__label {
    display: block;
    font-size: 8px;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    margin-bottom: 0.5rem;
  }
  .spellbound-meta-grid__value {
    color: #ffffff;
    font-size: 0.875rem;
    letter-spacing: 0.15em;
    border-left: 1px solid rgba(255,255,255,0.2);
    padding-left: 1rem;
  }

  /* Section container */
  .spellbound-product-extras {
    padding: 0 1.5rem 2rem;
    max-width: 87.5rem;
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .spellbound-product-extras {
      padding: 0 6rem 2rem;
    }
  }

  /* Description italic quote styling (CSS-only, no JS needed) */
  .product-information .product-details .rte p,
  .product-information .product-details [data-block-type="text"] .rte p {
    font-style: italic;
    color: rgba(255,255,255,0.4);
    font-size: 0.875rem;
    line-height: 1.6;
  }
</style>

{%- assign current_product = product -%}
{%- if current_product == blank -%}{%- break -%}{%- endif -%}

{%- capture planet_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.planet -%}{%- endcapture -%}
{%- capture element_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.element -%}{%- endcapture -%}
{%- capture zodiac_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.zodiac -%}{%- endcapture -%}
{%- capture chakra_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.chakra -%}{%- endcapture -%}
{%- capture crystal_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.crystal_type -%}{%- endcapture -%}
{%- capture intention_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.intention -%}{%- endcapture -%}
{%- capture theme_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.theme -%}{%- endcapture -%}
{%- assign handmade = current_product.metafields.custom.handmade -%}

{%- assign planet_clean = planet_clean | strip -%}
{%- assign element_clean = element_clean | strip -%}
{%- assign zodiac_clean = zodiac_clean | strip -%}
{%- assign chakra_clean = chakra_clean | strip -%}
{%- assign crystal_clean = crystal_clean | strip -%}
{%- assign intention_clean = intention_clean | strip -%}
{%- assign theme_clean = theme_clean | strip -%}

{%- assign has_any_meta = false -%}
{%- if planet_clean != blank or element_clean != blank or zodiac_clean != blank or chakra_clean != blank or crystal_clean != blank or intention_clean != blank or theme_clean != blank or handmade -%}
  {%- assign has_any_meta = true -%}
{%- endif -%}

{% if theme_clean != blank or handmade or has_any_meta %}
<div class="spellbound-product-extras">

  {%- comment -%} Theme + Handmade label {%- endcomment -%}
  {% if theme_clean != blank or handmade %}
    <span class="spellbound-theme-label">
      {%- if theme_clean != blank -%}{{ theme_clean }}{%- endif -%}
      {%- if theme_clean != blank and handmade %} &bull; {% endif -%}
      {%- if handmade -%}Handmade{%- endif -%}
    </span>
  {% endif %}

  {%- comment -%} Metafield properties grid {%- endcomment -%}
  {% if has_any_meta %}
    <div class="spellbound-meta-grid">
      {% if planet_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Primary Planet</span>
          <div class="spellbound-meta-grid__value">{{ planet_clean }}</div>
        </div>
      {% endif %}
      {% if element_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Ruling Element</span>
          <div class="spellbound-meta-grid__value">{{ element_clean }}</div>
        </div>
      {% endif %}
      {% if zodiac_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Zodiac Sign</span>
          <div class="spellbound-meta-grid__value">{{ zodiac_clean }}</div>
        </div>
      {% endif %}
      {% if chakra_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Chakra</span>
          <div class="spellbound-meta-grid__value">{{ chakra_clean }}</div>
        </div>
      {% endif %}
      {% if crystal_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Crystal</span>
          <div class="spellbound-meta-grid__value">{{ crystal_clean }}</div>
        </div>
      {% endif %}
      {% if intention_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Intention</span>
          <div class="spellbound-meta-grid__value">{{ intention_clean }}</div>
        </div>
      {% endif %}
      {% if theme_clean != blank %}
        <div>
          <span class="spellbound-meta-grid__label">Theme</span>
          <div class="spellbound-meta-grid__value">{{ theme_clean }}</div>
        </div>
      {% endif %}
      {% if handmade %}
        <div>
          <span class="spellbound-meta-grid__label">Craft</span>
          <div class="spellbound-meta-grid__value">Handmade</div>
        </div>
      {% endif %}
    </div>
  {% endif %}

</div>
{% endif %}

{% schema %}
{
  "name": "Spellbound Extras",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [],
  "templates": ["product"],
  "presets": [
    {
      "name": "Spellbound Extras"
    }
  ]
}
{% endschema %}
