{% comment %}
  Spellbound Discovery Grid - Reusable grid for Intentions/Zodiac/Elements navigation.
  Two card modes: compact icon card (no image) and 3/4 image card (image set).
  Consumes Candlelight tokens from assets/spellbound-custom.css only.
{% endcomment %}

<style>
  .spellbound-discovery {
    position: relative;
    padding: 3rem 1.5rem 5rem;
    background: var(--spellbound-bg);
  }
  .spellbound-discovery__atmosphere {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }
  .spellbound-discovery__atmosphere img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.14;
  }
  .spellbound-discovery__atmosphere::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      var(--spellbound-bg) 0%,
      rgba(13, 11, 16, 0) 32%,
      rgba(13, 11, 16, 0) 68%,
      var(--spellbound-bg) 100%
    );
  }
  @media (min-width: 990px) {
    .spellbound-discovery {
      padding: 7rem 6rem;
    }
  }
  .spellbound-discovery__inner {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
  }
  .spellbound-discovery__header {
    margin-bottom: var(--spellbound-module-gap);
    text-align: center;
  }
  @media (min-width: 768px) {
    .spellbound-discovery__header:not(.spellbound-discovery__header--centre) {
      text-align: left;
    }
    .spellbound-discovery__header {
      margin-bottom: var(--spellbound-space-16);
    }
  }
  .spellbound-discovery__divider {
    display: flex;
    align-items: center;
    width: 64px;
    margin: 1.1rem auto 0;
    color: var(--spellbound-gold);
  }
  .spellbound-discovery__divider::before,
  .spellbound-discovery__divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--spellbound-gold-deep);
  }
  .spellbound-discovery__divider svg {
    display: block;
    flex: none;
    width: 11px;
    height: 11px;
    margin: 0 6px;
  }
  @media (min-width: 768px) {
    .spellbound-discovery__header:not(.spellbound-discovery__header--centre) .spellbound-discovery__divider {
      margin-left: 0;
      margin-right: 0;
    }
  }
  .spellbound-discovery__title {
    font-family: var(--spellbound-type-display-family);
    font-weight: 400;
    font-size: var(--spellbound-type-section-title-size);
    line-height: var(--spellbound-leading-heading);
    color: var(--spellbound-text);
    margin: 0;
  }
  .spellbound-discovery__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .spellbound-discovery__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }
  }
  @media (min-width: 1024px) {
    .spellbound-discovery__grid--cols-3 {
      grid-template-columns: repeat(3, 1fr);
    }
    .spellbound-discovery__grid--cols-4 {
      grid-template-columns: repeat(4, 1fr);
    }
    .spellbound-discovery__grid--cols-5 {
      grid-template-columns: repeat(5, 1fr);
    }
    .spellbound-discovery__grid--cols-6 {
      grid-template-columns: repeat(6, 1fr);
    }
    .spellbound-discovery__grid--cols-7 {
      grid-template-columns: repeat(7, 1fr);
    }
  }
  .spellbound-discovery__card {
    position: relative;
    display: block;
    overflow: hidden;
    background-color: var(--spellbound-surface);
    background-image: radial-gradient(
      120% 90% at 0% 0%,
      rgba(255, 255, 255, 0.05) 0%,
      rgba(255, 255, 255, 0) 55%
    );
    border: 1px solid var(--spellbound-border);
    text-decoration: none;
    transition: border-color 0.3s ease;
  }
  .spellbound-discovery__card:hover {
    border-color: var(--spellbound-border-strong);
  }
  .spellbound-discovery__card:focus-visible {
    outline: 2px solid var(--spellbound-gold);
    outline-offset: 2px;
  }
  .spellbound-discovery__card--image {
    aspect-ratio: 3 / 4;
  }
  .spellbound-discovery__card-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-discovery__card:hover .spellbound-discovery__card-image {
    transform: scale(1.03);
  }
  .spellbound-discovery__card-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(13, 11, 16, 0.92) 0%,
      rgba(13, 11, 16, 0.5) 35%,
      rgba(13, 11, 16, 0) 65%
    );
    pointer-events: none;
  }
  .spellbound-discovery__card-content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1.25rem;
    z-index: 1;
  }
  @media (min-width: 990px) {
    .spellbound-discovery__card-content {
      padding: 2.5rem 1.5rem;
    }
  }
  .spellbound-discovery__card--image .spellbound-discovery__card-content {
    position: absolute;
    inset: auto 0 0 0;
    justify-content: flex-end;
    padding: 1.25rem 1rem 1.4rem;
  }
  .spellbound-discovery__card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--spellbound-gold-deep);
    background-color: transparent;
    margin-bottom: 1rem;
    color: var(--spellbound-gold);
    transition: color 0.3s ease, filter 0.3s ease, background-color 0.3s ease, border-color 0.3s ease;
  }
  .spellbound-discovery__card:hover .spellbound-discovery__card-icon {
    color: var(--spellbound-gold-bright);
    border-color: var(--spellbound-gold);
    background-color: var(--spellbound-gold-glow);
    filter: drop-shadow(0 0 10px var(--spellbound-gold-glow));
  }
  .spellbound-discovery__card-icon svg {
    display: block;
    width: 24px;
    height: 24px;
    stroke-width: 1;
  }
  .spellbound-discovery__card-name {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 1.05rem;
    color: var(--spellbound-text);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 0.35rem;
    text-align: center;
  }
  @media (min-width: 990px) {
    .spellbound-discovery__card-name {
      font-size: 1.25rem;
    }
  }
  .spellbound-discovery__card-desc {
    display: block;
    font-size: 0.78125rem;
    line-height: 1.5;
    letter-spacing: 0.05em;
    color: var(--spellbound-text-soft);
    text-align: center;
    max-width: 30ch;
    margin-left: auto;
    margin-right: auto;
  }
  .spellbound-discovery__card-topline {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--spellbound-gold-deep);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
  }
  .spellbound-discovery__card:hover .spellbound-discovery__card-topline {
    transform: scaleX(1);
  }
  .spellbound-discovery__card-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--spellbound-gold-deep);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.45s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 2;
  }
  .spellbound-discovery__card:hover .spellbound-discovery__card-accent {
    transform: scaleX(1);
    background: var(--spellbound-gold);
  }

  /* Constellation mode turns compact discovery cards into a single connected
     composition. The links keep generous rectangular hit areas, while the
     visible objects are sigil medallions rather than another row of boxes. */
  .spellbound-discovery--constellation {
    padding-block: clamp(4.5rem, 9vw, 8rem);
  }
  .spellbound-discovery--constellation .spellbound-discovery__atmosphere img {
    opacity: 0.22;
    object-position: center 58%;
  }
  .spellbound-discovery--constellation .spellbound-discovery__atmosphere::after {
    background:
      radial-gradient(circle at 50% 48%, rgba(13, 11, 16, 0.16), rgba(13, 11, 16, 0.72) 72%),
      linear-gradient(to bottom, var(--spellbound-bg), transparent 26%, transparent 72%, var(--spellbound-bg));
  }
  .spellbound-discovery__stage {
    position: relative;
  }
  .spellbound-discovery__constellation-map {
    display: none;
  }
  .spellbound-discovery__grid--constellation {
    position: relative;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem 0.75rem;
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card {
    min-width: 0;
    min-height: 13.5rem;
    overflow: visible;
    border: 0;
    background: none;
    isolation: isolate;
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: 6% -5% -3%;
    border-radius: 50%;
    background: radial-gradient(circle, var(--spellbound-gold-glow), transparent 67%);
    opacity: 0;
    transform: scale(0.86);
    transition: opacity 300ms ease, transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card:is(:hover, :focus-visible)::before {
    opacity: 1;
    transform: scale(1);
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card:focus-visible {
    border-radius: 0.75rem;
    outline-offset: 0.3rem;
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card-content {
    min-height: 13.5rem;
    padding: 1.25rem 0.5rem;
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card:is(:hover, :focus-visible) .spellbound-discovery__card-content {
    transform: translateY(-0.35rem);
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card-icon {
    position: relative;
    width: 4.5rem;
    height: 4.5rem;
    margin-bottom: 1.65rem;
    border-color: var(--spellbound-gold);
    background: rgba(13, 11, 16, 0.66);
    box-shadow:
      inset 0 0 0 0.3rem rgba(13, 11, 16, 0.8),
      inset 0 0 0 calc(0.3rem + 1px) var(--spellbound-gold-deep),
      0 0 2rem rgba(212, 175, 55, 0.08);
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card-icon::before {
    content: '';
    position: absolute;
    inset: -0.7rem;
    border: 1px solid var(--spellbound-gold-deep);
    transform: rotate(45deg);
    transition: border-color 300ms ease, transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card-icon::after {
    content: '';
    position: absolute;
    top: -0.85rem;
    left: calc(50% - 0.16rem);
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 50%;
    background: var(--spellbound-gold-bright);
    box-shadow: 0 6.2rem 0 var(--spellbound-gold-bright);
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card:is(:hover, :focus-visible) .spellbound-discovery__card-icon {
    color: var(--spellbound-gold-bright);
    border-color: var(--spellbound-gold-bright);
    background: rgba(42, 17, 43, 0.72);
    filter: drop-shadow(0 0 1rem var(--spellbound-gold-glow));
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card:is(:hover, :focus-visible) .spellbound-discovery__card-icon::before {
    border-color: var(--spellbound-gold);
    transform: rotate(50deg) scale(1.04);
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card-name {
    width: 100%;
    margin-bottom: 0.5rem;
    color: var(--spellbound-text);
    font-size: clamp(0.96875rem, 4vw, 1.25rem);
    letter-spacing: 0.04em;
    line-height: 1.15;
    overflow-wrap: normal;
    text-wrap: balance;
    transition: color 250ms ease;
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card:is(:hover, :focus-visible) .spellbound-discovery__card-name {
    color: var(--spellbound-gold-bright);
  }
  .spellbound-discovery__grid--constellation .spellbound-discovery__card-desc {
    max-width: 18ch;
    color: var(--spellbound-text-soft);
    font-size: 0.9375rem;
    line-height: 1.45;
    letter-spacing: 0.02em;
  }
  .spellbound-discovery__grid--constellation :is(.spellbound-discovery__card-topline, .spellbound-discovery__card-accent) {
    display: none;
  }
  @media (max-width: 359px) {
    .spellbound-discovery__grid--constellation {
      grid-template-columns: minmax(0, 1fr);
      gap: 0.5rem;
    }
    .spellbound-discovery__grid--constellation .spellbound-discovery__card,
    .spellbound-discovery__grid--constellation .spellbound-discovery__card-content {
      min-height: 12.5rem;
    }
  }
  @media (min-width: 768px) {
    .spellbound-discovery__grid--constellation {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2rem 1.25rem;
    }
    .spellbound-discovery__grid--constellation .spellbound-discovery__card-name {
      font-size: 1.25rem;
    }
  }
  @media (min-width: 1200px) {
    .spellbound-discovery--constellation .spellbound-discovery__header {
      margin-bottom: 2rem;
    }
    .spellbound-discovery__stage--constellation {
      padding-block: 1rem 3.75rem;
    }
    .spellbound-discovery__constellation-map {
      position: absolute;
      z-index: 0;
      inset: -0.5rem 1.5rem auto;
      display: block;
      width: calc(100% - 3rem);
      height: 17rem;
      overflow: visible;
      color: var(--spellbound-gold);
      pointer-events: none;
    }
    .spellbound-discovery__constellation-path {
      fill: none;
      stroke: currentColor;
      stroke-width: 1;
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      opacity: 0.38;
      transition: stroke-dashoffset 1200ms cubic-bezier(0.16, 1, 0.3, 1) 180ms;
    }
    .spellbound-discovery__constellation-map.is-visible .spellbound-discovery__constellation-path {
      stroke-dashoffset: 0;
    }
    .spellbound-discovery__constellation-star {
      fill: currentColor;
      opacity: 0.74;
    }
    .spellbound-discovery__grid--constellation {
      z-index: 1;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: clamp(0.5rem, 1.3vw, 1.1rem);
    }
    .spellbound-discovery__grid--constellation .spellbound-discovery__card:nth-child(1),
    .spellbound-discovery__grid--constellation .spellbound-discovery__card:nth-child(6) {
      margin-top: 3.75rem;
    }
    .spellbound-discovery__grid--constellation .spellbound-discovery__card:nth-child(2),
    .spellbound-discovery__grid--constellation .spellbound-discovery__card:nth-child(5) {
      margin-top: 1.6rem;
    }
    .spellbound-discovery__grid--constellation .spellbound-discovery__card:nth-child(3),
    .spellbound-discovery__grid--constellation .spellbound-discovery__card:nth-child(4) {
      margin-top: 0;
    }
    .spellbound-discovery__grid--constellation .spellbound-discovery__card-content {
      min-height: 14rem;
      padding-inline: 0.75rem;
    }
    .spellbound-discovery__grid--constellation .spellbound-discovery__card-name {
      font-size: clamp(1.05rem, 1.25vw, 1.3rem);
    }
  }

  .spellbound-discovery--zodiac { padding-block: clamp(4.5rem, 9vw, 8rem); }
  .spellbound-discovery--zodiac .spellbound-discovery__atmosphere img {
    opacity: 0.26;
    object-position: center;
  }
  .spellbound-discovery--zodiac .spellbound-discovery__atmosphere::after {
    background: radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--spellbound-bg) 18%, transparent), color-mix(in srgb, var(--spellbound-bg) 80%, transparent) 72%), linear-gradient(to bottom, var(--spellbound-bg), transparent 22%, transparent 78%, var(--spellbound-bg));
  }
  .spellbound-discovery__stage--zodiac {
    position: relative;
    padding-top: 0.75rem;
  }
  .spellbound-discovery__zodiac-map,
  .spellbound-discovery__zodiac-centre {
    display: none;
  }
  .spellbound-discovery__grid--zodiac {
    position: relative;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 0.5rem;
    row-gap: 2.25rem;
  }
  .spellbound-discovery__grid--zodiac::before {
    content: '';
    position: absolute;
    z-index: 0;
    inset-block: 3rem;
    inset-inline-start: 50%;
    inline-size: 1px;
    background: linear-gradient(to bottom, transparent, var(--spellbound-gold-deep) 8%, var(--spellbound-gold-deep) 92%, transparent);
    opacity: 0.6;
    pointer-events: none;
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card {
    z-index: 1;
    min-width: 0;
    min-height: 10.5rem;
    overflow: visible;
    border: 0;
    background: none;
    isolation: isolate;
    transition: opacity 800ms cubic-bezier(0.16, 1, 0.3, 1), transform 800ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(even) {
    translate: 0 1.5rem;
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card::before {
    content: '';
    position: absolute;
    z-index: -1;
    inset: 8% 2%;
    border-radius: 50%;
    background: radial-gradient(circle, var(--spellbound-gold-glow), transparent 66%);
    opacity: 0;
    transform: scale(0.82);
    transition: opacity 300ms ease, transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card:is(:hover, :focus-visible)::before {
    opacity: 1;
    transform: scale(1);
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card:focus-visible {
    border-radius: 50%;
    outline-offset: 0.15rem;
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card-content {
    min-height: 10.5rem;
    padding: 1rem 0.35rem;
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card:is(:hover, :focus-visible) .spellbound-discovery__card-content {
    transform: translateY(-0.3rem);
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card-icon {
    position: relative;
    width: 4.25rem;
    height: 4.25rem;
    margin-bottom: 1.35rem;
    border-color: var(--spellbound-gold);
    background: radial-gradient(circle, color-mix(in srgb, var(--spellbound-purple-deep) 82%, transparent), color-mix(in srgb, var(--spellbound-bg) 90%, transparent) 70%);
    box-shadow: inset 0 0 0 0.28rem color-mix(in srgb, var(--spellbound-bg) 82%, transparent), inset 0 0 0 calc(0.28rem + 1px) var(--spellbound-gold-deep), 0 0 1.5rem color-mix(in srgb, var(--spellbound-gold) 8%, transparent);
    transition: color 300ms ease, border-color 300ms ease, filter 300ms ease, transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card-icon::before {
    content: '';
    position: absolute;
    inset: -0.65rem;
    border: 1px solid color-mix(in srgb, var(--spellbound-gold) 42%, transparent);
    border-right-color: transparent;
    border-radius: 50%;
    transform: rotate(-24deg);
    transition: border-color 300ms ease, transform 500ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card-icon::after {
    content: '';
    position: absolute;
    top: -0.78rem;
    left: calc(50% - 0.15rem);
    width: 0.3rem;
    height: 0.3rem;
    border-radius: 50%;
    background: var(--spellbound-gold-bright);
    box-shadow: 0 5.55rem 0 color-mix(in srgb, var(--spellbound-gold-bright) 72%, transparent);
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card:is(:hover, :focus-visible) .spellbound-discovery__card-icon {
    color: var(--spellbound-gold-bright);
    border-color: var(--spellbound-gold-bright);
    filter: drop-shadow(0 0 0.9rem var(--spellbound-gold-glow));
    transform: scale(1.04);
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card:is(:hover, :focus-visible) .spellbound-discovery__card-icon::before {
    border-color: var(--spellbound-gold);
    border-left-color: transparent;
    transform: rotate(20deg);
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card-name {
    width: 100%;
    margin: 0;
    color: var(--spellbound-text);
    font-size: clamp(0.95rem, 4.3vw, 1.2rem);
    line-height: 1.15;
    letter-spacing: 0.055em;
    overflow-wrap: normal;
    text-wrap: balance;
    transition: color 250ms ease;
  }
  .spellbound-discovery__grid--zodiac .spellbound-discovery__card:is(:hover, :focus-visible) .spellbound-discovery__card-name {
    color: var(--spellbound-gold-bright);
  }
  .spellbound-discovery__grid--zodiac :is(.spellbound-discovery__card-topline, .spellbound-discovery__card-accent) {
    display: none;
  }
  @media (min-width: 768px) and (max-width: 1199px) {
    .spellbound-discovery__grid--zodiac {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      column-gap: 1rem;
      row-gap: 2.5rem;
    }
    .spellbound-discovery__grid--zodiac::before {
      display: none;
    }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(even) {
      translate: 0;
    }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(3n + 2) {
      translate: 0 1.75rem;
    }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card-name {
      font-size: 1.2rem;
    }
  }
  @media (min-width: 1200px) {
    .spellbound-discovery--zodiac .spellbound-discovery__header {
      margin-bottom: 0;
    }
    .spellbound-discovery__stage--zodiac {
      min-height: 48rem;
      padding-top: 0;
    }
    .spellbound-discovery__zodiac-map {
      position: absolute;
      z-index: 0;
      inset: 0;
      display: block;
      width: 100%;
      height: 100%;
      overflow: visible;
      color: var(--spellbound-gold);
      pointer-events: none;
    }
    .spellbound-discovery__zodiac-orbit,
    .spellbound-discovery__zodiac-axis {
      fill: none;
      stroke: currentColor;
      stroke-width: 1;
      opacity: 0.28;
    }
    .spellbound-discovery__zodiac-orbit {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      transition: stroke-dashoffset 1400ms cubic-bezier(0.16, 1, 0.3, 1) 160ms;
    }
    .spellbound-discovery__zodiac-map.is-visible .spellbound-discovery__zodiac-orbit {
      stroke-dashoffset: 0;
    }
    .spellbound-discovery__zodiac-axis {
      stroke-dasharray: 2 10;
      opacity: 0.16;
    }
    .spellbound-discovery__zodiac-star {
      fill: currentColor;
      opacity: 0.72;
    }
    .spellbound-discovery__zodiac-centre {
      position: absolute;
      z-index: 1;
      top: 50%;
      left: 50%;
      display: grid;
      place-items: center;
      width: 9rem;
      height: 9rem;
      color: var(--spellbound-gold);
      border: 1px solid color-mix(in srgb, var(--spellbound-gold) 32%, transparent);
      border-radius: 50%;
      background: radial-gradient(circle, color-mix(in srgb, var(--spellbound-purple-deep) 50%, transparent), color-mix(in srgb, var(--spellbound-bg) 68%, transparent) 68%);
      box-shadow: inset 0 0 0 0.65rem color-mix(in srgb, var(--spellbound-bg) 40%, transparent), 0 0 4rem color-mix(in srgb, var(--spellbound-gold) 8%, transparent);
      translate: -50% -50%;
      pointer-events: none;
    }
    .spellbound-discovery__zodiac-centre svg {
      width: 4.5rem;
      height: 4.5rem;
      fill: none;
      stroke: currentColor;
      stroke-width: 1;
    }
    .spellbound-discovery__grid--zodiac {
      position: absolute;
      z-index: 2;
      inset: 0;
      display: block;
    }
    .spellbound-discovery__grid--zodiac::before {
      display: none;
    }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card {
      position: absolute;
      width: clamp(8.5rem, 10vw, 10.5rem);
      min-height: 8.75rem;
      translate: -50% -50%;
    }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(even) {
      translate: -50% -50%;
    }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card-content {
      min-height: 8.75rem;
      padding: 0.75rem 0.35rem;
    }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card-name {
      font-size: clamp(1rem, 1.2vw, 1.22rem);
    }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(1) { left: 50%; top: 12%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(2) { left: 72%; top: 16%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(3) { left: 87%; top: 31%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(4) { left: 91%; top: 50%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(5) { left: 87%; top: 69%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(6) { left: 72%; top: 84%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(7) { left: 50%; top: 88%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(8) { left: 28%; top: 84%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(9) { left: 13%; top: 69%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(10) { left: 9%; top: 50%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(11) { left: 13%; top: 31%; }
    .spellbound-discovery__grid--zodiac .spellbound-discovery__card:nth-child(12) { left: 28%; top: 16%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .spellbound-discovery__card,
    .spellbound-discovery__card-image,
    .spellbound-discovery__card-icon,
    .spellbound-discovery__card-icon::before,
    .spellbound-discovery__card::before,
    .spellbound-discovery__card-content,
    .spellbound-discovery__card-name,
    .spellbound-discovery__card-topline,
    .spellbound-discovery__card-accent,
    .spellbound-discovery__constellation-path,
    .spellbound-discovery__zodiac-orbit {
      transition: none !important;
      transform: none !important;
    }
    .spellbound-discovery__constellation-path,
    .spellbound-discovery__zodiac-orbit {
      stroke-dashoffset: 0;
    }
  }
</style>

{% render 'spellbound-ornament' %}
<section class="spellbound-discovery spellbound-discovery--{{ section.settings.layout_style }}">
  {% if section.settings.atmosphere_asset != blank %}
    <div class="spellbound-discovery__atmosphere" aria-hidden="true">
      {% if section.settings.atmosphere_asset == 'spellbound-img-hero-desktop.webp' %}
        <img
          src="{{ 'spellbound-img-hero-desktop-1600.webp' | asset_url }}"
          srcset="
            {{ 'spellbound-img-hero-desktop-960.webp' | asset_url }} 960w,
            {{ 'spellbound-img-hero-desktop-1600.webp' | asset_url }} 1600w,
            {{ 'spellbound-img-hero-desktop-2400.webp' | asset_url }} 2400w
          "
          sizes="100vw"
          alt=""
          width="5126"
          height="3072"
          loading="lazy"
          decoding="async"
        >
      {% else %}
        <img
          src="{{ section.settings.atmosphere_asset | asset_url }}"
          alt=""
          width="968"
          height="545"
          loading="lazy"
        >
      {% endif %}
    </div>
  {% endif %}
  <div class="spellbound-discovery__inner">
    <header class="spellbound-discovery__header{% if section.settings.centre_header %} spellbound-discovery__header--centre{% endif %}" data-spellbound-reveal>
      {% if section.settings.title != blank %}
        <h2 class="spellbound-discovery__title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}<p class="spellbound-discovery__intro">{{ section.settings.description | escape }}</p>{% endif %}
      {% if section.settings.title != blank %}
        <div class="spellbound-discovery__divider" aria-hidden="true">
          <svg viewBox="0 0 12 12" xmlns="http://www.w3.org/2000/svg" fill="currentColor">
            <path d="M6 0 7.35 4.65 12 6 7.35 7.35 6 12 4.65 7.35 0 6 4.65 4.65Z"/>
          </svg>
        </div>
      {% endif %}
    </header>

    <div class="spellbound-discovery__stage{% if section.settings.layout_style == 'constellation' %} spellbound-discovery__stage--constellation{% elsif section.settings.layout_style == 'zodiac' %} spellbound-discovery__stage--zodiac{% endif %}">
      {% if section.settings.layout_style == 'constellation' %}
        <svg
          class="spellbound-discovery__constellation-map"
          viewBox="0 0 1200 270"
          preserveAspectRatio="none"
          aria-hidden="true"
          data-spellbound-reveal
        >
          <path class="spellbound-discovery__constellation-path" pathLength="1" d="M70 155 C145 140 195 120 275 110 S430 82 510 88 S690 88 770 88 S940 100 1010 110 S1090 140 1130 155"/>
          <circle class="spellbound-discovery__constellation-star" cx="70" cy="155" r="2.5"/>
          <circle class="spellbound-discovery__constellation-star" cx="275" cy="110" r="2.5"/>
          <circle class="spellbound-discovery__constellation-star" cx="510" cy="88" r="2.5"/>
          <circle class="spellbound-discovery__constellation-star" cx="770" cy="88" r="2.5"/>
          <circle class="spellbound-discovery__constellation-star" cx="1010" cy="110" r="2.5"/>
          <circle class="spellbound-discovery__constellation-star" cx="1130" cy="155" r="2.5"/>
        </svg>
      {% endif %}
      {% if section.settings.layout_style == 'zodiac' %}
        <svg
          class="spellbound-discovery__zodiac-map"
          viewBox="0 0 1200 700"
          preserveAspectRatio="none"
          aria-hidden="true"
          data-spellbound-reveal
        >
          <ellipse class="spellbound-discovery__zodiac-orbit" pathLength="1" cx="600" cy="350" rx="530" ry="292"/>
          <ellipse class="spellbound-discovery__zodiac-orbit" pathLength="1" cx="600" cy="350" rx="430" ry="232"/>
          <path class="spellbound-discovery__zodiac-axis" d="M70 350H1130M600 58V642"/>
          <circle class="spellbound-discovery__zodiac-star" cx="600" cy="58" r="3"/>
          <circle class="spellbound-discovery__zodiac-star" cx="1130" cy="350" r="3"/>
          <circle class="spellbound-discovery__zodiac-star" cx="600" cy="642" r="3"/>
          <circle class="spellbound-discovery__zodiac-star" cx="70" cy="350" r="3"/>
        </svg>
        <div class="spellbound-discovery__zodiac-centre" aria-hidden="true" data-spellbound-reveal>
          <svg viewBox="0 0 72 72">
            <circle cx="36" cy="36" r="10"/>
            <path d="M36 7v10M36 55v10M7 36h10M55 36h10M15.5 15.5l7 7M49.5 49.5l7 7M56.5 15.5l-7 7M22.5 49.5l-7 7"/>
            <path d="M47.5 30.5A14 14 0 1 0 47.5 49 15 15 0 0 1 47.5 30.5Z"/>
          </svg>
        </div>
      {% endif %}
      <div
        class="spellbound-discovery__grid spellbound-discovery__grid--cols-{{ section.settings.columns }}{% if section.settings.layout_style == 'constellation' %} spellbound-discovery__grid--constellation{% elsif section.settings.layout_style == 'zodiac' %} spellbound-discovery__grid--zodiac{% endif %}"
        data-spellbound-reveal-group
      >
        {% for block in section.blocks %}
          {% liquid
            assign has_image = false
            if block.settings.image != blank
              assign has_image = true
            endif
          %}
          <a
            class="spellbound-discovery__card{% if has_image %} spellbound-discovery__card--image{% endif %}"
            {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% endif %}
            {{ block.shopify_attributes }}
          >
            <span class="spellbound-discovery__card-topline" aria-hidden="true"></span>
            {% if has_image %}
              <img
                class="spellbound-discovery__card-image"
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 800 }} 800w"
                sizes="(min-width: 1024px) 20vw, (min-width: 768px) 33vw, 50vw"
                alt="{{ block.settings.image.alt | default: block.settings.card_title | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
              <div class="spellbound-discovery__card-gradient"></div>
            {% endif %}
            <div class="spellbound-discovery__card-content">
              {% if block.settings.icon != blank %}
                <div class="spellbound-discovery__card-icon" aria-hidden="true">
                  {{ block.settings.icon }}
                </div>
              {% endif %}
              <h3 class="spellbound-discovery__card-name">{{ block.settings.card_title }}</h3>
              {% if block.settings.description != blank %}
                <span class="spellbound-discovery__card-desc">{{ block.settings.description }}</span>
              {% endif %}
            </div>
            <span class="spellbound-discovery__card-accent" aria-hidden="true"></span>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Spellbound Discovery Grid",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Elements"
    },
    { "type": "textarea", "id": "description", "label": "Description" },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 3,
      "max": 7,
      "step": 1,
      "default": 5
    },
    {
      "type": "select",
      "id": "layout_style",
      "label": "Layout style",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "constellation", "label": "Constellation" },
        { "value": "zodiac", "label": "Zodiac wheel" }
      ],
      "default": "grid"
    },
    {
      "type": "text",
      "id": "atmosphere_asset",
      "label": "Atmosphere image asset",
      "info": "Theme asset filename (e.g. spellbound-img-zodiac.jpg) rendered as a faint backdrop behind the section"
    },
    {
      "type": "checkbox",
      "id": "centre_header",
      "label": "Centre header",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "card_title",
          "label": "Title",
          "default": "Earth"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "html",
          "id": "icon",
          "label": "Icon SVG",
          "info": "Paste an SVG icon here"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Spellbound Discovery Grid",
      "blocks": [
        { "type": "card", "settings": { "card_title": "Earth" } },
        { "type": "card", "settings": { "card_title": "Air" } },
        { "type": "card", "settings": { "card_title": "Fire" } },
        { "type": "card", "settings": { "card_title": "Water" } },
        { "type": "card", "settings": { "card_title": "Spirit" } }
      ]
    }
  ]
}
{% endschema %}
