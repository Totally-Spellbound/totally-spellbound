{% comment %}
  Spellbound Collection Header - Compact cinematic collection title
{% endcomment %}

<style>
  .spellbound-collection-header {
    position: relative;
    display: grid;
    align-items: center;
    min-height: clamp(15rem, 64vw, 19rem);
    padding: clamp(3rem, 12vw, 5rem) 1.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--spellbound-gold-deep);
    overflow: hidden;
    isolation: isolate;
  }
  @media (min-width: 1024px) {
    .spellbound-collection-header {
      min-height: clamp(17rem, 22vw, 21rem);
      padding: 4.5rem clamp(3rem, 6vw, 7rem);
    }
  }
  .spellbound-collection-header__bg {
    position: absolute;
    inset: 0;
    background: var(--spellbound-surface);
    z-index: 0;
  }
  .spellbound-collection-header__bg img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 52%;
    opacity: 0.78;
  }
  .spellbound-collection-header__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        rgba(13, 11, 16, 0.9) 0%,
        rgba(13, 11, 16, 0.58) 30%,
        rgba(13, 11, 16, 0.2) 50%,
        rgba(13, 11, 16, 0.58) 72%,
        rgba(13, 11, 16, 0.9) 100%
      ),
      linear-gradient(to bottom, rgba(13, 11, 16, 0.2), rgba(13, 11, 16, 0.68));
  }
  .spellbound-collection-header__inner {
    position: relative;
    z-index: 1;
    width: 100%;
  }
  .spellbound-collection-header__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    align-items: end;
    gap: 1.25rem;
  }
  @media (min-width: 768px) {
    .spellbound-collection-header__row {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: clamp(3rem, 10vw, 12rem);
    }
  }
  .spellbound-collection-header__title {
    font-family: var(--spellbound-type-display-family);
    font-weight: 400;
    font-size: var(--spellbound-type-page-title-size);
    color: var(--spellbound-text);
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0;
    max-width: 14ch;
    text-wrap: balance;
  }
  .spellbound-collection-header__count {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    width: fit-content;
    color: var(--spellbound-text);
    font-family: var(--spellbound-type-reading-family);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0.035em;
    white-space: nowrap;
    text-shadow: 0 2px 18px rgba(13, 11, 16, 0.9);
  }
  .spellbound-collection-header__count::before {
    content: '';
    display: block;
    width: clamp(2rem, 5vw, 3.5rem);
    height: 1px;
    background: var(--spellbound-gold);
    box-shadow: 0 0 14px var(--spellbound-gold-glow);
  }
  @media (min-width: 768px) {
    .spellbound-collection-header__count {
      justify-self: end;
      padding-bottom: 0.3rem;
      font-size: 1.125rem;
      text-align: right;
    }
  }
  .spellbound-collection-header__quote {
    color: var(--spellbound-text-soft);
    font-family: var(--font-accent--family, var(--font-heading--family));
    font-style: italic;
    font-size: 1rem;
    max-width: 40rem;
    margin: 1rem 0 0;
  }
</style>

{%- assign header_image = section.settings.background_image -%}
{%- if header_image == blank and collection != blank and collection.image != blank -%}
  {%- assign header_image = collection.image -%}
{%- endif -%}
{%- assign header_asset = section.settings.background_image_asset -%}

{%- comment -%} Automatic atmospheric backdrop per collection handle {%- endcomment -%}
{%- if header_image == blank and header_asset == blank -%}
  {%- assign handle = collection.handle | default: '' -%}
  {%- assign zodiac_handles = 'aries,taurus,gemini,cancer,leo,virgo,libra,scorpio,sagittarius,capricorn,aquarius,pisces' | split: ',' -%}
  {%- case handle -%}
    {%- when 'crystals-stones' -%}
      {%- assign header_asset = 'spellbound-img-cat-crystals.jpg' -%}
    {%- when 'tarot-oracle' -%}
      {%- assign header_asset = 'spellbound-img-cat-tarot.jpg' -%}
    {%- when 'incense-burners' -%}
      {%- assign header_asset = 'spellbound-img-cat-incense.jpg' -%}
    {%- when 'books-guides' -%}
      {%- assign header_asset = 'spellbound-img-cat-books.jpg' -%}
    {%- when 'altar-home' -%}
      {%- assign header_asset = 'spellbound-img-cat-altar.jpg' -%}
    {%- when 'handmade' -%}
      {%- assign header_asset = 'spellbound-img-cat-handmade.jpg' -%}
    {%- else -%}
      {%- if zodiac_handles contains handle -%}
        {%- assign header_asset = 'spellbound-img-zodiac.jpg' -%}
      {%- elsif handle contains 'planet-' -%}
        {%- assign header_asset = 'spellbound-img-oracle.jpg' -%}
      {%- elsif handle contains '-chakra' or handle contains 'crystal-' -%}
        {%- assign header_asset = 'spellbound-img-cat-crystals.jpg' -%}
      {%- else -%}
        {%- assign header_asset = 'spellbound-img-hero-desktop.webp' -%}
      {%- endif -%}
  {%- endcase -%}
{%- endif -%}

<section class="spellbound-collection-header">
  {%- if header_image != blank or header_asset != blank -%}
    <div class="spellbound-collection-header__bg" aria-hidden="true">
      {%- if header_image != blank -%}
        {{
          header_image
          | image_url: width: 1800
          | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '100vw', alt: '', widths: '750, 1100, 1500, 1800'
        }}
      {%- elsif header_asset == 'spellbound-img-hero-desktop.webp' -%}
        <img
          src="{{ 'spellbound-img-hero-desktop-1600.webp' | asset_url }}"
          srcset="
            {{ 'spellbound-img-hero-desktop-960.webp' | asset_url }} 960w,
            {{ 'spellbound-img-hero-desktop-1600.webp' | asset_url }} 1600w,
            {{ 'spellbound-img-hero-desktop-2400.webp' | asset_url }} 2400w,
            {{ 'spellbound-img-hero-desktop-3200.webp' | asset_url }} 3200w,
            {{ 'spellbound-img-hero-desktop.webp' | asset_url }} 5126w
          "
          sizes="100vw"
          alt=""
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="5126"
          height="3072"
        >
      {%- else -%}
        <img
          src="{{ header_asset | asset_url }}"
          alt=""
          loading="lazy"
          width="1800"
          height="900"
        >
      {%- endif -%}
      <div class="spellbound-collection-header__scrim"></div>
    </div>
  {%- endif -%}

  <div class="spellbound-collection-header__inner" data-spellbound-reveal-group>
    <div class="spellbound-collection-header__row">
      <h1 class="spellbound-collection-header__title">
        {%- if collection != blank -%}
          {{ collection.title }}
        {%- else -%}
          {{ section.settings.fallback_title }}
        {%- endif -%}
      </h1>
      {%- if collection != blank -%}
        <span class="spellbound-collection-header__count">
          {{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}
        </span>
      {%- endif -%}
    </div>

    {%- if section.settings.quote != blank -%}
      <p class="spellbound-collection-header__quote">&ldquo;{{ section.settings.quote }}&rdquo;</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Spellbound Col Header",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "background_image_asset",
      "label": "Background asset filename",
      "info": "Fallback theme asset (e.g. spellbound-img-vault.jpg) used when no background image is picked"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback title",
      "default": "All Artifacts",
      "info": "Shown when no collection is available"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote"
    }
  ],
  "presets": [
    {
      "name": "Spellbound Col Header"
    }
  ]
}
{% endschema %}
