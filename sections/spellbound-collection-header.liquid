{% comment %}
  Spellbound Collection Header - Cinematic collection title with background
{% endcomment %}

<style>
  .spellbound-collection-header {
    position: relative;
    padding: 6rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    margin-bottom: 4rem;
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .spellbound-collection-header {
      padding: 6rem;
    }
  }
  .spellbound-collection-header__bg {
    position: absolute;
    inset: 0;
    opacity: 0.1;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    filter: grayscale(100%);
  }
  .spellbound-collection-header__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  @media (min-width: 768px) {
    .spellbound-collection-header__inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }
  .spellbound-collection-header__text {
    max-width: 36rem;
  }
  .spellbound-collection-header__label {
    color: #f59e0b;
    font-size: 10px;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 1.5rem;
  }
  .spellbound-collection-header__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(3.5rem, 7vw, 7rem);
    color: #ffffff;
    letter-spacing: -0.03em;
    line-height: 0.9;
    margin-bottom: 1.5rem;
  }
  .spellbound-collection-header__quote {
    color: rgba(255,255,255,0.4);
    font-style: italic;
    font-size: 0.875rem;
  }
  .spellbound-collection-header__meta {
    text-align: right;
  }
  .spellbound-collection-header__count {
    font-size: 10px;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }
  .spellbound-collection-header__divider {
    width: 100%;
    height: 1px;
    background: rgba(255,255,255,0.1);
  }
</style>

<section class="spellbound-collection-header">
  {% if section.settings.background_image != blank %}
    <div
      class="spellbound-collection-header__bg"
      style="background-image: url('{{ section.settings.background_image | image_url: width: 2000 }}')"
    ></div>
  {% endif %}
  <div class="spellbound-collection-header__inner">
    <div class="spellbound-collection-header__text">
      {% if section.settings.label != blank %}
        <span class="spellbound-collection-header__label">{{ section.settings.label }}</span>
      {% endif %}
      <h1 class="spellbound-collection-header__title">
        {% if collection != blank %}
          {{ collection.title }}
        {% else %}
          {{ section.settings.fallback_title }}
        {% endif %}
      </h1>
      {% if section.settings.quote != blank %}
        <p class="spellbound-collection-header__quote">"{{ section.settings.quote }}"</p>
      {% endif %}
    </div>
    <div class="spellbound-collection-header__meta">
      {% if collection != blank %}
        <div class="spellbound-collection-header__count">
          {{ collection.products_count }} Manifestations Found
        </div>
      {% endif %}
      <div class="spellbound-collection-header__divider"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Spellbound Col Header",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Browsing The Archives"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback title",
      "default": "The Vault",
      "info": "Shown when no collection is available"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "Each item in this collection has been vetted for spiritual integrity and aesthetic weight."
    }
  ],
  "presets": [
    {
      "name": "Spellbound Col Header"
    }
  ]
}
{% endschema %}
