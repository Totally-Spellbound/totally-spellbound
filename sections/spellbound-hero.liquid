{% comment %}
  Spellbound Hero - Full-screen cinematic hero with dark overlay
{% endcomment %}

<style>
  .spellbound-hero {
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #050505;
  }
  .spellbound-hero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.1);
  }
  .spellbound-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.6), #050505);
    z-index: 1;
  }
  .spellbound-hero__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: 0 1.5rem;
  }
  .spellbound-hero__label {
    color: rgba(253, 230, 138, 0.6);
    font-size: 10px;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }
  .spellbound-hero__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(3rem, 8vw, 8rem);
    line-height: 0.8;
    color: #ffffff;
    margin-bottom: 3rem;
  }
  .spellbound-hero__heading em {
    font-family: var(--font-accent--family);
    font-style: italic;
    font-weight: var(--font-accent--weight);
  }
  .spellbound-hero__cta {
    display: inline-block;
    padding: 1.25rem 3rem;
    background: #ffffff;
    color: #000000;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.4em;
    text-decoration: none;
    transition: background 0.5s ease;
  }
  .spellbound-hero__cta:hover {
    background: #fde68a;
  }
</style>

<section class="spellbound-hero">
  {% if section.settings.image != blank %}
    {%- assign image = section.settings.image -%}
    <img
      src="{{ image | image_url: width: 2000 }}"
      srcset="{{ image | image_url: width: 1000 }} 1000w, {{ image | image_url: width: 1500 }} 1500w, {{ image | image_url: width: 2000 }} 2000w"
      sizes="100vw"
      alt="{{ section.settings.heading | escape }}"
      class="spellbound-hero__media"
      loading="eager"
      fetchpriority="high"
      width="{{ image.width }}"
      height="{{ image.height }}"
    >
  {% endif %}
  <div class="spellbound-hero__overlay"></div>
  <div class="spellbound-hero__content spellbound-fade-in">
    {% if section.settings.label != blank %}
      <p class="spellbound-hero__label">{{ section.settings.label }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h1 class="spellbound-hero__heading">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link }}" class="spellbound-hero__cta">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Spellbound Hero",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label text",
      "default": "Artifacts for the Soul"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p><em>Ethereal</em> Eminence</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Enter The Vault"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Spellbound Hero"
    }
  ]
}
{% endschema %}
