{% comment %}
  Spellbound Hero - cinematic full-bleed hero.
  Candlelight tokens only (no hardcoded accent hex). Ken Burns zoom,
  dual gradient scrim, reveal-on-scroll content, scroll cue.
{% endcomment %}

<style>
  .spellbound-section.spellbound-section--hero {
    padding: 0;
  }

  .spellbound-hero {
    position: relative;
    display: flex;
    align-items: stretch;
    min-height: max(
      75vh,
      calc(var(--header-height, 4.5rem) + var(--header-group-height, 0px) + 22rem)
    );
    min-height: max(
      75svh,
      calc(var(--header-height, 4.5rem) + var(--header-group-height, 0px) + 22rem)
    );
    overflow: hidden;
    background: var(--spellbound-bg);
  }

  .spellbound-hero__media-wrap {
    position: absolute;
    inset: 0;
    background: var(--spellbound-surface);
    overflow: hidden;
  }

  .spellbound-hero__media-wrap picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .spellbound-hero__media {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: spellbound-hero-kenburns 14s ease-in-out infinite alternate;
    will-change: transform;
  }

  @keyframes spellbound-hero-kenburns {
    from { transform: scale(1); }
    to { transform: scale(1.06); }
  }

  .spellbound-hero__scrim {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        to right,
        rgba(13, 11, 16, 0.94) 0%,
        rgba(13, 11, 16, 0.82) 28%,
        rgba(13, 11, 16, 0.56) 48%,
        rgba(13, 11, 16, 0.14) 72%,
        rgba(13, 11, 16, 0) 86%
      ),
      linear-gradient(
        to top,
        var(--spellbound-bg) 0%,
        rgba(13, 11, 16, 0.72) 22%,
        rgba(13, 11, 16, 0.28) 52%,
        rgba(13, 11, 16, 0.12) 74%,
        rgba(13, 11, 16, 0.3) 100%
      ),
      radial-gradient(
        130% 100% at 50% 32%,
        rgba(0, 0, 0, 0) 42%,
        rgba(0, 0, 0, 0.42) 100%
      ),
      radial-gradient(
        55% 45% at 82% 8%,
        var(--spellbound-violet-glow) 0%,
        rgba(0, 0, 0, 0) 70%
      );
    pointer-events: none;
  }

  .spellbound-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    padding: calc(var(--header-height, 4.5rem) + var(--header-group-height, 0px)) clamp(1.5rem, 5vw, 5rem) 0;
    text-align: center;
  }

  .spellbound-hero__heading {
    margin: 0 auto 1.25rem;
    max-width: 16ch;
    font-family: var(--spellbound-type-display-family);
    font-weight: 400;
    font-size: var(--spellbound-type-display-size);
    line-height: var(--spellbound-leading-display);
    color: var(--spellbound-text);
    text-wrap: balance;
  }

  .spellbound-hero__heading em {
    font-family: inherit;
    font-style: normal;
    color: var(--spellbound-gold-bright);
  }

  .spellbound-hero__subheading {
    margin: 0 auto 2.25rem;
    max-width: 34rem;
    font-family: var(--spellbound-type-reading-family);
    font-size: clamp(var(--spellbound-type-body-size), 1.4vw, var(--spellbound-type-description-size));
    line-height: var(--spellbound-leading-body);
    color: var(--spellbound-text-soft);
  }

  .spellbound-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .spellbound-hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.1rem 2.6rem;
    font-family: var(--font-body--family, serif);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      background 0.45s ease,
      color 0.45s ease,
      border-color 0.45s ease,
      box-shadow 0.45s ease;
  }

  .spellbound-hero__cta:focus-visible {
    outline: 2px solid var(--spellbound-gold);
    outline-offset: 3px;
  }

  .spellbound-hero__cta--primary {
    background: var(--spellbound-gold);
    color: var(--spellbound-bg);
    border: 1px solid var(--spellbound-gold);
  }

  .spellbound-hero__cta--primary:hover {
    background: var(--spellbound-gold-bright);
    border-color: var(--spellbound-gold-bright);
    color: var(--spellbound-bg);
    box-shadow:
      0 0 34px var(--spellbound-gold-glow),
      0 0 14px var(--spellbound-gold-glow);
  }

  .spellbound-hero__cta--ghost {
    background: transparent;
    color: var(--spellbound-text);
    border: 1px solid var(--spellbound-border-strong);
  }

  .spellbound-hero__cta--ghost:hover {
    border-color: var(--spellbound-gold);
    color: var(--spellbound-gold);
  }

  .spellbound-hero__scroll {
    position: absolute;
    z-index: 2;
    right: clamp(1.5rem, 4vw, 3.5rem);
    bottom: clamp(2.5rem, 8svh, 5rem);
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    pointer-events: none;
  }

  .spellbound-hero__scroll-label {
    font-family: var(--font-body--family, serif);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--spellbound-text-faint);
    writing-mode: vertical-rl;
  }

  .spellbound-hero__scroll-line {
    position: relative;
    width: 1px;
    height: 56px;
    background: var(--spellbound-border);
    overflow: hidden;
  }

  .spellbound-hero__scroll-line::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 1px;
    height: 18px;
    background: var(--spellbound-gold);
    animation: spellbound-hero-scroll-cue 2.4s cubic-bezier(0.16, 1, 0.3, 1) infinite;
  }

  @keyframes spellbound-hero-scroll-cue {
    0% { transform: translateY(-20px); }
    70% { transform: translateY(58px); }
    100% { transform: translateY(58px); }
  }

  @media screen and (min-width: 750px) {
    .spellbound-hero__content {
      text-align: left;
    }

    .spellbound-hero__heading,
    .spellbound-hero__subheading {
      margin-left: 0;
      margin-right: 0;
    }

    .spellbound-hero__actions {
      justify-content: flex-start;
    }

    .spellbound-hero__scroll {
      display: flex;
    }
  }

  @media screen and (min-width: 990px) {
    .spellbound-hero__heading {
      max-width: 13.5ch;
      font-size: clamp(3rem, 5vw, 5rem);
    }

    .spellbound-hero__subheading {
      max-width: 30rem;
      font-size: clamp(1.125rem, 1.35vw, 1.25rem);
      font-weight: 500;
      color: var(--spellbound-text);
    }

    .spellbound-hero__cta--ghost {
      background: rgba(13, 11, 16, 0.48);
    }
  }

  @media screen and (max-width: 749px) {
    .spellbound-hero__media {
      transform-origin: center top;
    }

    .spellbound-hero__scrim {
      background:
        linear-gradient(
          to bottom,
          rgba(13, 11, 16, 0.78) 0%,
          rgba(13, 11, 16, 0.72) 70%,
          rgba(13, 11, 16, 0.42) 88%,
          var(--spellbound-bg) 100%
        ),
        radial-gradient(
          120% 90% at 50% 26%,
          rgba(13, 11, 16, 0.08) 30%,
          rgba(13, 11, 16, 0.48) 100%
        );
    }

    .spellbound-hero__content {
      padding-inline: 1.25rem;
    }

    .spellbound-hero__heading {
      margin-bottom: var(--spellbound-space-3);
      max-width: 15ch;
      font-size: clamp(2rem, 8.75vw, 2.5rem);
      line-height: var(--spellbound-leading-display);
    }

    .spellbound-hero__subheading {
      margin-bottom: var(--spellbound-space-4);
      max-width: 31ch;
      font-size: var(--spellbound-type-body-size);
      font-weight: 500;
      line-height: var(--spellbound-leading-body);
      color: var(--spellbound-text);
    }

    .spellbound-hero__actions {
      flex-direction: column;
      align-items: center;
    }

    .spellbound-hero__cta {
      min-height: 48px;
    }

    .spellbound-hero__cta--primary {
      min-width: min(18rem, 100%);
      padding: 0.9rem 2rem;
    }

    .spellbound-hero__cta--ghost {
      display: none;
    }
  }

  @media screen and (max-height: 640px) {
    .spellbound-hero__scroll {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .spellbound-hero__media {
      animation: none;
    }

    .spellbound-hero__scroll {
      display: none;
    }
  }
</style>

{%- liquid
  assign hero_alt = section.settings.heading | strip_html | strip
  assign desktop_image_asset = section.settings.image_asset | default: 'spellbound-img-hero-desktop.webp'
  assign desktop_image_asset_1600 = desktop_image_asset | replace: '.webp', '-1600.webp'
  assign desktop_image_asset_2400 = desktop_image_asset | replace: '.webp', '-2400.webp'
  assign desktop_image_asset_3200 = desktop_image_asset | replace: '.webp', '-3200.webp'
  assign mobile_image_asset = section.settings.mobile_image_asset | default: 'spellbound-img-hero-mobile.webp'
  assign mobile_image_asset_600 = mobile_image_asset | replace: '.webp', '-600.webp'
  assign mobile_image_asset_900 = mobile_image_asset | replace: '.webp', '-900.webp'
  assign mobile_image_asset_1200 = mobile_image_asset | replace: '.webp', '-1200.webp'
  if hero_alt == blank
    assign hero_alt = shop.name
  endif
-%}

<section class="spellbound-hero">
  <div class="spellbound-hero__media-wrap" aria-hidden="false">
    {%- if section.settings.image != blank or section.settings.image_asset != blank -%}
      <picture>
        <source
          media="(max-width: 749px)"
          srcset="
            {{ mobile_image_asset_600 | asset_url }} 600w,
            {{ mobile_image_asset_900 | asset_url }} 900w,
            {{ mobile_image_asset_1200 | asset_url }} 1200w,
            {{ mobile_image_asset | asset_url }} 1776w
          "
          sizes="100vw"
          type="image/webp"
          width="1776"
          height="2368"
        >
        {%- if section.settings.image != blank -%}
          {%- assign image = section.settings.image -%}
          <img
            src="{{ image | image_url: width: 2000 }}"
            srcset="
              {{ image | image_url: width: 800 }} 800w,
              {{ image | image_url: width: 1200 }} 1200w,
              {{ image | image_url: width: 1600 }} 1600w,
              {{ image | image_url: width: 2000 }} 2000w,
              {{ image | image_url: width: 2600 }} 2600w
            "
            sizes="100vw"
            alt="{{ hero_alt | escape }}"
            class="spellbound-hero__media"
            loading="eager"
            fetchpriority="high"
            width="{{ image.width }}"
            height="{{ image.height }}"
          >
        {%- else -%}
          <img
            src="{{ desktop_image_asset | asset_url }}"
            {% if desktop_image_asset == 'spellbound-img-hero-desktop.webp' %}
              srcset="
                {{ desktop_image_asset_1600 | asset_url }} 1600w,
                {{ desktop_image_asset_2400 | asset_url }} 2400w,
                {{ desktop_image_asset_3200 | asset_url }} 3200w,
                {{ desktop_image_asset | asset_url }} 5126w
              "
              sizes="100vw"
            {% endif %}
            alt="{{ hero_alt | escape }}"
            class="spellbound-hero__media"
            loading="eager"
            fetchpriority="high"
            width="5126"
            height="3072"
          >
        {%- endif -%}
      </picture>
    {%- endif -%}
  </div>
  <div class="spellbound-hero__scrim"></div>

  <div class="spellbound-hero__content" data-spellbound-reveal-group>
    {%- if section.settings.heading != blank -%}
      <h1 class="spellbound-hero__heading">
        {{- section.settings.heading | replace: '<p>', '<span>' | replace: '</p>', '</span>' -}}
      </h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="spellbound-hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank or section.settings.button2_label != blank -%}
      <div class="spellbound-hero__actions">
        {%- if section.settings.button_label != blank -%}
          <a
            href="{{ section.settings.button_link | default: '/collections/all' }}"
            class="spellbound-hero__cta spellbound-hero__cta--primary"
          >
            {{- section.settings.button_label -}}
          </a>
        {%- endif -%}
        {%- if section.settings.button2_label != blank -%}
          <a
            href="{{ section.settings.button2_link | default: '#oracle' }}"
            class="spellbound-hero__cta spellbound-hero__cta--ghost"
          >
            {{- section.settings.button2_label -}}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>

  <div class="spellbound-hero__scroll" aria-hidden="true">
    <span class="spellbound-hero__scroll-label">Scroll</span>
    <span class="spellbound-hero__scroll-line"></span>
  </div>
</section>

{% schema %}
{
  "name": "Spellbound Hero",
  "tag": "section",
  "class": "spellbound-section spellbound-section--hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Fallback asset filename",
      "default": "spellbound-img-hero-desktop.webp",
      "info": "Desktop theme asset used when no image is picked"
    },
    {
      "type": "text",
      "id": "mobile_image_asset",
      "label": "Mobile background asset filename",
      "default": "spellbound-img-hero-mobile.webp",
      "info": "Portrait WebP master used below 750px with matching -600, -900 and -1200 variants"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Every crystal holds a <em>story</em>.</p>"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Hand-picked crystals, tarot & curiosities from a real little shop in Nottinghamshire."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Enter the Vault"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Secondary button label",
      "default": "Consult the Oracle"
    },
    {
      "type": "text",
      "id": "button2_link",
      "label": "Secondary button link",
      "default": "#oracle",
      "info": "Accepts anchors like #oracle or a relative URL"
    }
  ],
  "presets": [
    {
      "name": "Spellbound Hero"
    }
  ]
}
{% endschema %}
