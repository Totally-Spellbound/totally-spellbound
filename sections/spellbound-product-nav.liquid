{% comment %}
  Spellbound Product Nav
  "Return to Vault" back link above main product section.
{% endcomment %}

<style>
  .spellbound-product-nav {
    padding: 1.5rem 1.5rem 0;
    max-width: 87.5rem;
    margin: 0 auto;
  }
  @media (min-width: 1024px) {
    .spellbound-product-nav {
      padding: 1.5rem 6rem 0;
    }
  }
  .spellbound-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--spellbound-text-soft);
    text-decoration: none;
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    transition: color 0.3s ease;
  }
  .spellbound-back-link:hover { color: var(--spellbound-gold-bright); }
  .spellbound-back-link svg {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-back-link:hover svg { transform: translateX(-4px); }
  @media (prefers-reduced-motion: reduce) {
    .spellbound-back-link svg { transition: none; }
    .spellbound-back-link:hover svg { transform: none; }
  }
</style>

<div class="spellbound-product-nav">
  <a href="{{ collection.url | default: routes.all_products_collection_url }}" class="spellbound-back-link">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    Return to Vault
  </a>
</div>

{% schema %}
{
  "name": "Spellbound Nav",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [],
  "presets": [
    {
      "name": "Spellbound Nav"
    }
  ]
}
{% endschema %}
