{% comment %}
  Spellbound Story - "Proudly Independent" split editorial section.
  Image left / content right, info card with address + hours, ghost CTA.
  Candlelight tokens only (no hardcoded accent hex).
{% endcomment %}

<style>
  .spellbound-story {
    padding: clamp(3rem, 6vw, 5rem) 1.5rem clamp(4rem, 9vw, 7.5rem);
    background: var(--spellbound-bg);
    position: relative;
  }
  .spellbound-story__inner {
    max-width: 72rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 990px) {
    .spellbound-story__inner {
      grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
      gap: clamp(3rem, 6vw, 5.5rem);
    }
  }
  .spellbound-story__media-frame {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--spellbound-surface);
    border: 1px solid var(--spellbound-border);
    border-radius: 10px;
    box-shadow:
      0 30px 80px -24px rgba(0, 0, 0, 0.7),
      0 0 60px var(--spellbound-gold-glow);
  }
  .spellbound-story__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .spellbound-story__heading {
    font-family: var(--spellbound-type-display-family);
    font-weight: 400;
    font-size: var(--spellbound-type-section-title-size);
    line-height: var(--spellbound-leading-heading);
    color: var(--spellbound-text);
    margin: 0 0 1.5rem;
  }
  .spellbound-story__body {
    font-family: var(--spellbound-type-reading-family);
    font-size: var(--spellbound-type-description-size);
    line-height: var(--spellbound-leading-description);
    color: var(--spellbound-text-soft);
    margin-bottom: 1.75rem;
  }
  .spellbound-story__body p {
    margin: 0 0 1em;
  }
  .spellbound-story__body p:last-child {
    margin-bottom: 0;
  }
  .spellbound-story__quote {
    font-family: var(--spellbound-type-reading-family);
    font-style: italic;
    font-size: 1.375rem;
    line-height: 1.5;
    color: var(--spellbound-text);
    border-left: 2px solid var(--spellbound-gold-deep);
    padding-left: 1.25rem;
    margin: 0 0 2rem;
  }
  .spellbound-story__card {
    background: var(--spellbound-surface);
    border: 1px solid var(--spellbound-border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    margin-bottom: 2rem;
  }
  .spellbound-story__card-row {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-family: var(--spellbound-type-reading-family);
    font-size: var(--spellbound-type-body-size);
    line-height: var(--spellbound-leading-body);
    color: var(--spellbound-text-soft);
  }
  .spellbound-story__card-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 0.1em;
    color: var(--spellbound-gold);
  }
  .spellbound-story__cta {
    display: inline-block;
    font-family: var(--font-body--family);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--spellbound-text);
    text-decoration: none;
    border: 1px solid var(--spellbound-border-strong);
    border-radius: 100px;
    padding: 0.9rem 1.9rem;
    transition: color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .spellbound-story__cta:hover,
  .spellbound-story__cta:focus-visible {
    color: var(--spellbound-gold-bright);
    border-color: var(--spellbound-gold-bright);
    box-shadow: 0 0 24px var(--spellbound-gold-glow);
  }
  @media (max-width: 749px) {
    .spellbound-story__cta {
      display: block;
      width: fit-content;
      margin-inline: auto;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .spellbound-story__cta {
      transition: none;
    }
  }
</style>

{% render 'spellbound-ornament' %}
<section class="spellbound-story">
  <div class="spellbound-story__inner">
    <div class="spellbound-story__media" data-spellbound-reveal>
      <div class="spellbound-story__media-frame">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="{{ section.settings.image | image_url: width: 500 }} 500w, {{ section.settings.image | image_url: width: 750 }} 750w, {{ section.settings.image | image_url: width: 1100 }} 1100w"
            sizes="(min-width: 990px) 45vw, 100vw"
            alt="{{ section.settings.image.alt | default: 'Inside Totally Spellbound, our shop in Sutton-in-Ashfield' | escape }}"
            class="spellbound-story__image"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {% elsif section.settings.image_asset != blank %}
          <img
            src="{{ section.settings.image_asset | asset_url }}"
            alt="Inside Totally Spellbound, our shop in Sutton-in-Ashfield"
            class="spellbound-story__image"
            loading="lazy"
            width="800"
            height="1000"
            onerror="this.style.visibility='hidden'"
          >
        {% endif %}
      </div>
    </div>

    <div class="spellbound-story__content" data-spellbound-reveal>
      {% if section.settings.heading != blank %}
        <h2 class="spellbound-story__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}
      {% if section.settings.body != blank %}
        <div class="spellbound-story__body">{{ section.settings.body }}</div>
      {% endif %}
      {% if section.settings.quote != blank %}
        <blockquote class="spellbound-story__quote">&ldquo;{{ section.settings.quote | escape }}&rdquo;</blockquote>
      {% endif %}

      {% if section.settings.address_text != blank or section.settings.hours_text != blank %}
        <div class="spellbound-story__card">
          {% if section.settings.address_text != blank %}
            <div class="spellbound-story__card-row">
              <svg class="spellbound-story__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <path d="M12 21s-7-5.6-7-11a7 7 0 1 1 14 0c0 5.4-7 11-7 11z"/>
                <circle cx="12" cy="10" r="2.5"/>
              </svg>
              <span>{{ section.settings.address_text | escape }}</span>
            </div>
          {% endif %}
          {% if section.settings.hours_text != blank %}
            <div class="spellbound-story__card-row">
              <svg class="spellbound-story__card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                <circle cx="12" cy="12" r="9"/>
                <path d="M12 7v5l3 2"/>
              </svg>
              <span>{{ section.settings.hours_text | escape }}</span>
            </div>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_link | default: '#' }}" class="spellbound-story__cta">{{ section.settings.cta_label | escape }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Spellbound Story",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A real little shop in Sutton-in-Ashfield"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Totally Spellbound is Alison's real little shop - no corporate warehouse, no endless aisles. Every crystal, deck and curiosity on our shelves is chosen by hand, and many are one-of-a-kind: the exact piece you see is the exact piece that arrives.</p><p>Pop in for a browse, a chat, or a bit of guidance - the kettle's usually on.</p>"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Pull quote",
      "default": "Helpful like a conversation in the shop - never pushy."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Plan Your Visit"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Fallback image asset",
      "default": "spellbound-img-our-story.webp",
      "info": "Theme asset filename used when no image is picked."
    },
    {
      "type": "text",
      "id": "address_text",
      "label": "Address",
      "default": "108 Outram Street, Sutton-in-Ashfield NG17 4FS"
    },
    {
      "type": "text",
      "id": "hours_text",
      "label": "Opening hours",
      "default": "Mon-Sat 10am-4pm · Closed Sundays"
    }
  ],
  "presets": [
    {
      "name": "Spellbound Story"
    }
  ]
}
{% endschema %}
