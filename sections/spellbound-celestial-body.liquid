    box-shadow: 0 -590px 150px #000 inset, 0 0 130px 40px rgba(234,205,199,0.6) inset, 0 0 23px 4px rgba(234,205,199,0.6) inset, 0 -10px 130px 30px rgba(234,205,199,0.4);
  }
  .spellbound-celestial--mercury .spellbound-celestial__type { color: #f7dad3; }
  .spellbound-celestial--mercury .spellbound-celestial__read-more { color: #E8927C; border-color: #E8927C; }
  .spellbound-celestial--mercury .spellbound-celestial__moon-label { color: #E8927C; }

