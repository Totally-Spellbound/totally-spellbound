{% comment %}
  Spellbound Celestial Body - Visual planet display for product pages
  Renders the matching celestial body with textured sphere, moons,
  orbit lines, and description based on custom.planet metafield.
{% endcomment %}

{%- assign current_product = product -%}
{%- assign planet_meta = current_product.metafields.custom.planet.value -%}

{%- comment -%} Find the first supported planet from the metafield array {%- endcomment -%}
{%- assign supported_planets = 'mercury,venus,earth,mars,jupiter,saturn,uranus,neptune,pluto' | split: ',' -%}
{%- assign planet_found = false -%}
{%- assign planet_name = '' -%}
{%- assign planet_display = '' -%}

{%- if planet_meta.size > 0 -%}
  {%- for planet_val in planet_meta -%}
    {%- assign planet_check = planet_val | strip | downcase -%}
    {%- for p in supported_planets -%}
      {%- if planet_check == p -%}
        {%- assign planet_found = true -%}
        {%- assign planet_name = p -%}
        {%- assign planet_display = planet_val | strip -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if planet_found -%}{%- break -%}{%- endif -%}
  {%- endfor -%}
{%- else -%}
  {%- comment -%} Fallback: single value or raw string {%- endcomment -%}
  {%- capture planet_raw -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.planet -%}{%- endcapture -%}
  {%- assign planet_check = planet_raw | strip | downcase -%}
  {%- for p in supported_planets -%}
    {%- if planet_check == p -%}
      {%- assign planet_found = true -%}
      {%- assign planet_name = p -%}
      {%- assign planet_display = planet_raw | strip -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- if planet_found -%}

{%- comment -%} Planet type {%- endcomment -%}
{%- if planet_name == 'pluto' -%}
  {%- assign planet_type = 'Dwarf Planet' -%}
{%- else -%}
  {%- assign planet_type = 'Planet' -%}
{%- endif -%}

{%- comment -%} Planet descriptions {%- endcomment -%}
{%- case planet_name -%}
  {%- when 'mercury' -%}
    {%- assign planet_desc = 'The closest planet to the sun. It circles the sun faster than all the other planets, which is why Romans named it after their swift-footed messenger god.' -%}
  {%- when 'venus' -%}
    {%- assign planet_desc = 'Named for the Roman goddess of love and beauty. In ancient times, Venus was often thought to be two different stars, the evening star and the morning star.' -%}
  {%- when 'earth' -%}
    {%- assign planet_desc = 'Earth, our home. It is the only planet known to have an atmosphere containing free oxygen, oceans of liquid water on its surface, and, of course, life.' -%}
  {%- when 'mars' -%}
    {%- assign planet_desc = 'Fourth planet from the Sun and the second smallest planet in the solar system. Named after the Roman god of war, often described as the "Red Planet".' -%}
  {%- when 'jupiter' -%}
    {%- assign planet_desc = 'Jupiter is the largest planet in the solar system. Fittingly, it was named after the king of the gods in Roman mythology.' -%}
  {%- when 'saturn' -%}
    {%- assign planet_desc = 'Saturn is the sixth planet from the sun and the second largest planet in the solar system. Saturn was the Roman name for Cronus, the lord of the Titans.' -%}
  {%- when 'uranus' -%}
    {%- assign planet_desc = 'The first planet to be discovered by scientists. The planet is notable for its dramatic tilt, which causes its axis to point nearly directly at the sun.' -%}
  {%- when 'neptune' -%}
    {%- assign planet_desc = 'Neptune is the eighth planet from the sun. It was the first planet to get its existence predicted by mathematical calculations before it was actually seen through a telescope.' -%}
  {%- when 'pluto' -%}
    {%- assign planet_desc = 'Pluto, once considered the ninth and most distant planet from the sun, is now the largest known dwarf planet in the solar system.' -%}
{%- endcase -%}

<style>
  .spellbound-celestial {
    position: relative;
    width: 100%;
    height: 600px;
    overflow: hidden;
    background: #000;
    font-family: "Montserrat", var(--font-body--family), sans-serif;
  }
  @media (min-width: 750px) {
    .spellbound-celestial { height: 700px; }
  }

  /* Planet sphere */
  .spellbound-celestial__sphere {
    position: absolute;
    left: 50%;
    bottom: -550px;
    width: 900px;
    height: 900px;
    border-radius: 50%;
    transform: translateX(-50%) scaleX(0.89);
    background-size: 860px 700px;
    animation: spellbound-planet-rotate 80s linear infinite;
    z-index: 1;
  }
  @media (min-width: 750px) {
    .spellbound-celestial__sphere {
      width: 1200px;
      height: 1200px;
      bottom: -780px;
      background-size: 1140px 910px;
    }
  }
  @keyframes spellbound-planet-rotate {
    from { background-position-y: 0px; }
    to { background-position-y: -1000px; }
  }

  /* Atmosphere overlay - creates the shadow/glow over the sphere */
  .spellbound-celestial__atmosphere {
    position: absolute;
    left: 50%;
    bottom: -550px;
    width: 900px;
    height: 900px;
    border-radius: 50%;
    transform: translateX(-50%) scaleX(0.89);
    z-index: 2;
    pointer-events: none;
  }
  @media (min-width: 750px) {
    .spellbound-celestial__atmosphere {
      width: 1200px;
      height: 1200px;
      bottom: -780px;
    }
  }

  /* Dark overlay above the sphere horizon */
  .spellbound-celestial__horizon {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 1800px;
    height: 620px;
    bottom: -20px;
    border-radius: 100%;
    z-index: 3;
    box-shadow: 0px -190px 215px 110px #000 inset;
    pointer-events: none;
  }
  @media (min-width: 750px) {
    .spellbound-celestial__horizon {
      bottom: -60px;
    }
  }
  /* Bottom fade to ensure no bright texture leaks */
  .spellbound-celestial::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 120px;
    background: linear-gradient(to top, #000 0%, #000 20%, transparent 100%);
    z-index: 3;
    pointer-events: none;
  }

  /* Description text - positioned just above planet horizon */
  .spellbound-celestial__info {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    bottom: 160px;
    width: 90%;
    max-width: 620px;
    text-align: center;
    z-index: 5;
    color: #fff;
    text-transform: uppercase;
    font-weight: 300;
  }
  @media (min-width: 750px) {
    .spellbound-celestial__info {
      bottom: 190px;
    }
  }
  .spellbound-celestial__type {
    font-size: 10px;
    letter-spacing: 5px;
    margin: 0 0 6px 0;
    font-weight: 300;
  }
  .spellbound-celestial__name {
    font-size: 28px;
    letter-spacing: 14px;
    margin: 0 0 18px 0;
    font-weight: 300;
    line-height: 1.2;
    text-transform: uppercase !important;
  }
  @media (min-width: 750px) {
    .spellbound-celestial__name {
      font-size: 34px;
      letter-spacing: 16px;
    }
  }
  .spellbound-celestial__desc {
    font-size: 10px;
    letter-spacing: 3px;
    line-height: 22px;
    margin: 10px 0 14px;
    font-weight: 300;
    opacity: 0.85;
    text-transform: uppercase;
  }
  .spellbound-celestial__read-more {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 5px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0 2px 5px 0;
    border-bottom: 2px solid;
    transition: all 0.2s;
    cursor: pointer;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
  }
  .spellbound-celestial__read-more:hover {
    padding: 0 10px 5px 10px;
  }

  /* Moon elements */
  .spellbound-celestial__moon {
    position: absolute;
    z-index: 6;
    text-align: center;
    color: #fff;
    text-transform: uppercase;
  }
  .spellbound-celestial__moon-sphere {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background-size: auto 100%;
    background-color: #444;
    box-shadow: 0px -20px 20px 4px rgba(0,0,0,0.7) inset;
    margin: 0 auto 12px;
  }
  @media (min-width: 750px) {
    .spellbound-celestial__moon-sphere {
      width: 90px;
      height: 90px;
    }
  }
  .spellbound-celestial__moon-label {
    font-size: 10px;
    letter-spacing: 4px;
    margin: 0 0 2px;
    font-weight: 300;
  }
  .spellbound-celestial__moon-name {
    font-size: 16px;
    letter-spacing: 5px;
    margin: 0;
    font-weight: 300;
  }
  @media (min-width: 750px) {
    .spellbound-celestial__moon-name {
      font-size: 22px;
    }
  }

  /* Orbit trajectory lines - only top arcs visible via clip-path.
     Each orbit is clipped to show only the top ~15% (the arc above the planet). */
  .spellbound-celestial__orbit {
    position: absolute;
    border: 2px dashed rgba(255,255,255,0.2);
    border-radius: 50%;
    z-index: 4;
    pointer-events: none;
  }

  /* Moon positions - placed along visible orbit arcs */
  /* Phobos (pos2) upper-left, Deimos (pos1) right side */
  .spellbound-celestial__moon--pos1 { right: 20%; top: 25%; }
  .spellbound-celestial__moon--pos2 { left: 18%; top: 15%; }
  .spellbound-celestial__moon--pos3 { right: 22%; top: 130px; }
  @media (min-width: 750px) {
    .spellbound-celestial__moon--pos1 { right: 22%; top: 25%; }
    .spellbound-celestial__moon--pos2 { left: 18%; top: 15%; }
    .spellbound-celestial__moon--pos3 { right: 26%; top: 140px; }
  }

  /* Orbit line positions - centered on planet center
     Mobile: planet center at bottom:-190px. Orbit bottom = -190 - size/2
     Desktop: planet center at bottom:-320px. Orbit bottom = -320 - size/2 */
  /* Mobile: planet center at bottom -100px. Orbit bottom = -100 - size/2 */
  .spellbound-celestial__orbit--1 {
    width: 2000px; height: 2000px;
    left: 50%; bottom: -1100px;
    transform: translateX(-50%);
  }
  .spellbound-celestial__orbit--2 {
    width: 2200px; height: 2200px;
    left: 50%; bottom: -1200px;
    transform: translateX(-50%);
  }
  .spellbound-celestial__orbit--3 {
    width: 2400px; height: 2400px;
    left: 50%; bottom: -1300px;
    transform: translateX(-50%);
  }
  @media (min-width: 750px) {
    /* Desktop: planet center at bottom -180px. Orbit bottom = -180 - size/2 */
    .spellbound-celestial__orbit--1 { width: 2000px; height: 2000px; bottom: -1180px; }
    .spellbound-celestial__orbit--2 { width: 2200px; height: 2200px; bottom: -1280px; }
    .spellbound-celestial__orbit--3 { width: 2400px; height: 2400px; bottom: -1380px; }
  }

  /* Planet-specific textures and glows */
  .spellbound-celestial--mercury .spellbound-celestial__sphere {
    background-image: url("https://www.solarsystemscope.com/images/textures/full/2k_makemake_fictional.jpg");
  }
