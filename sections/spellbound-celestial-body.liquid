  /* Read More sliding panel */
  .spellbound-celestial__panel {
    position: absolute;
    right: -420px;
    top: 0;
    width: 360px;
    height: 100%;
    background: #fff;
    color: #000;
    z-index: 20;
    overflow-y: auto;
    padding: 50px 40px;
    transition: right 0.4s cubic-bezier(0.33, 0, 0, 1);
  }
  .spellbound-celestial__panel.is-open {
    right: 0;
  }
  .spellbound-celestial__panel-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    color: #000;
    font-size: 24px;
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
  }
  .spellbound-celestial__panel h2 {
    text-transform: uppercase;
    font-weight: 300;
    font-size: 20px;
    letter-spacing: 3px;
    margin: 0 0 8px;
  }
  .spellbound-celestial__panel h2::after {
    content: '';
    display: block;
    width: 30px;
    height: 2px;
    background: #000;
    margin-top: 8px;
    margin-bottom: 24px;
  }
  .spellbound-celestial__panel p {
    color: #777;
    font-size: 12px;
    line-height: 20px;
    margin: 0 0 16px;
  }
  .spellbound-celestial__panel h3 {
    font-size: 13px;
    text-transform: uppercase;
    font-weight: 600;
    margin: 28px 0 0;
  }
  .spellbound-celestial__panel h3::after {
    content: '';
    display: block;
    width: 30px;
    height: 2px;
    background: #000;
    margin-top: 6px;
    margin-bottom: 10px;
  }

  /* Backdrop overlay when panel is open */
  .spellbound-celestial__backdrop {
    display: none;
    position: absolute;
    inset: 0;
    z-index: 15;
    background: rgba(0,0,0,0.5);
    cursor: pointer;
  }
  .spellbound-celestial__panel.is-open ~ .spellbound-celestial__backdrop {
    display: block;
  }

  /* Section label above */
  .spellbound-celestial__section-label {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 6;
    color: #f59e0b;
    font-size: 9px;
