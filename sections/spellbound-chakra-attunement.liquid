{% comment %}
  Spellbound Chakra Attunement
  Interactive seven-chakra column + kindred artifacts that share the product's
  chakra metafield (case-insensitive, list-metafield aware on both sides).
  Renders only when product.metafields.custom.chakra is set.
{% endcomment %}

{%- capture chakra_raw -%}{%- render 'spellbound-metafield-value', value: product.metafields.custom.chakra -%}{%- endcapture -%}
{%- assign chakra_raw = chakra_raw | strip -%}

{%- if chakra_raw != blank -%}

{%- comment -%} Normalise the product's chakra value(s) into |key| tokens {%- endcomment -%}
{%- assign chakra_values = chakra_raw | downcase | split: ',' -%}
{%- assign chakra_keys = '|' -%}
{%- for value in chakra_values -%}
  {%- assign key = value | replace: 'chakra', '' | strip | replace: ' ', '' | replace: '-', '' | replace: '_', '' -%}
  {%- if key != '' -%}
    {%- assign chakra_keys = chakra_keys | append: key | append: '|' -%}
  {%- endif -%}
{%- endfor -%}

{%- comment -%} Chakra data, Crown (top) down to Root {%- endcomment -%}
{%- assign node_slugs = 'crown,third-eye,throat,heart,solar-plexus,sacral,root' | split: ',' -%}
{%- assign node_keys = 'crown,thirdeye,throat,heart,solarplexus,sacral,root' | split: ',' -%}
{%- assign node_en = 'Crown,Third Eye,Throat,Heart,Solar Plexus,Sacral,Root' | split: ',' -%}
{%- assign node_sa = 'Sahasrara,Ajna,Vishuddha,Anahata,Manipura,Svadhisthana,Muladhara' | split: ',' -%}
{%- assign node_colours = '#cfc7f2,#7c6bd8,#4d9de5,#4dbd7c,#e5c04d,#f0883e,#e5484d' | split: ',' -%}
{%- assign node_meanings = 'Connection and higher purpose — the quiet crown where self opens to spirit.|Intuition and inner vision — trusting the knowing that arrives before words.|Truth and clear expression — speaking honestly, gently, without fear.|Love, compassion and healing — the still centre where giving meets receiving.|Confidence and personal power — the steady fire that turns intention into action.|Creativity, pleasure and flow — the warm current behind joy and making.|Grounding, safety and belonging — deep roots for everything that grows above.' | split: '|' -%}

{%- comment -%} Which nodes are attuned, plus display name + default detail {%- endcomment -%}
{%- assign active_count = 0 -%}
{%- assign active_display = '' -%}
{%- assign default_index = -1 -%}
{%- for key in node_keys -%}
  {%- assign wrapped = '|' | append: key | append: '|' -%}
  {%- if chakra_keys contains wrapped -%}
    {%- assign active_count = active_count | plus: 1 -%}
    {%- if default_index == -1 -%}
      {%- assign default_index = forloop.index0 -%}
    {%- endif -%}
    {%- if active_display == '' -%}
      {%- assign active_display = node_en[forloop.index0] -%}
    {%- else -%}
      {%- assign active_display = active_display | append: ' & ' | append: node_en[forloop.index0] -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}
{%- if active_count == 0 -%}
  {%- assign active_display = chakra_raw | split: ',' | first | strip | capitalize -%}
{%- endif -%}

<style>
  .spellbound-chakra {
    position: relative;
    padding: 6rem 1.5rem;
    background: var(--spellbound-bg, #050505);
    border-bottom: 1px solid var(--spellbound-border);
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .spellbound-chakra { padding: 8rem 4rem; }
  }

  /* Faint night-sky atmosphere, fading into the page at top and bottom */
  .spellbound-chakra__atmos {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 25%, black 75%, transparent);
    mask-image: linear-gradient(to bottom, transparent, black 25%, black 75%, transparent);
  }
  .spellbound-chakra__atmos img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.15;
    filter: brightness(0.85);
  }
  .spellbound-chakra__layout {
    position: relative;
    z-index: 1;
  }
  .spellbound-chakra__layout {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .spellbound-chakra__layout {
      flex-direction: row;
      gap: 5rem;
      align-items: flex-start;
    }
  }

  /* ---- Chakra column (left / top) ---- */
  .spellbound-chakra__aside {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }
  @media (min-width: 1024px) {
    .spellbound-chakra__aside {
      flex: 0 0 14rem;
      position: sticky;
      top: 6rem;
    }
  }
  .spellbound-chakra__nodes {
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 0.65rem;
  }
  /* connecting spine line */
  .spellbound-chakra__nodes::before {
    content: '';
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    top: 50%;
    height: 1px;
    background: var(--spellbound-border);
  }
  @media (min-width: 1024px) {
    .spellbound-chakra__nodes {
      flex-direction: column;
      gap: 1rem;
    }
    .spellbound-chakra__nodes::before {
      left: 50%;
      right: auto;
      top: 0.75rem;
      bottom: 0.75rem;
      height: auto;
      width: 1px;
    }
  }
  .spellbound-chakra__node {
    position: relative;
    width: 44px;
    height: 44px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--spellbound-bg, #050505);
    border: 1px solid var(--spellbound-text-faint);
    color: var(--spellbound-text-faint);
    cursor: pointer;
    transition:
      color 0.4s ease,
      border-color 0.4s ease,
      box-shadow 0.4s ease,
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (min-width: 1024px) {
    .spellbound-chakra__node { width: 52px; height: 52px; }
  }
  .spellbound-chakra__node svg { display: block; }
  .spellbound-chakra__node:hover {
    color: var(--spellbound-text-soft);
    border-color: var(--spellbound-text-soft);
  }
  .spellbound-chakra__node:focus-visible {
    outline: 2px solid var(--spellbound-gold);
    outline-offset: 3px;
  }
  .spellbound-chakra__node.is-attuned,
  .spellbound-chakra__node.is-attuned:hover {
    color: var(--chakra-colour);
    border-color: var(--chakra-colour);
    box-shadow:
      0 0 14px 2px var(--spellbound-gold-glow),
      0 0 36px 6px var(--spellbound-gold-glow);
    box-shadow:
      0 0 12px 2px color-mix(in srgb, var(--chakra-colour) 55%, transparent),
      0 0 32px 6px color-mix(in srgb, var(--chakra-colour) 28%, transparent),
      0 0 64px 14px color-mix(in srgb, var(--chakra-colour) 14%, transparent);
    transform: scale(1.12);
  }

  /* Smoke wisps drifting up from attuned nodes — CSS only, colour-matched aura */
  .spellbound-chakra__node.is-attuned::before,
  .spellbound-chakra__node.is-attuned::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 30%;
    width: 40px;
    height: 110px;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(40% 30% at 50% 80%, var(--spellbound-gold-glow), transparent 72%);
    background:
      radial-gradient(38% 26% at 50% 82%, color-mix(in srgb, var(--chakra-colour) 55%, transparent), transparent 72%),
      radial-gradient(26% 34% at 38% 48%, color-mix(in srgb, var(--chakra-colour) 32%, transparent), transparent 70%),
      radial-gradient(22% 30% at 62% 20%, color-mix(in srgb, var(--chakra-colour) 20%, transparent), transparent 70%);
    filter: blur(7px);
    opacity: 0.45;
    -webkit-mask-image: linear-gradient(to top, black 12%, rgba(0, 0, 0, 0.55) 55%, transparent 96%);
    mask-image: linear-gradient(to top, black 12%, rgba(0, 0, 0, 0.55) 55%, transparent 96%);
    transform: translate(-50%, 0);
    transform-origin: 50% 100%;
    animation: spellbound-chakra-wisp 12s ease-in-out -3s infinite alternate;
  }
  .spellbound-chakra__node.is-attuned::after {
    left: 58%;
    width: 28px;
    height: 84px;
    opacity: 0.35;
    filter: blur(6px);
    animation-duration: 9s;
    animation-delay: -6s;
  }
  @keyframes spellbound-chakra-wisp {
    0% {
      transform: translate(-50%, 0) rotate(-3deg) scale(1);
      opacity: 0.32;
    }
    50% {
      opacity: 0.55;
    }
    100% {
      transform: translate(-46%, -16px) rotate(4deg) scale(1.14);
      opacity: 0.4;
    }
  }

  .spellbound-chakra__node[aria-pressed='true'] {
    outline: 1px solid var(--spellbound-gold-deep);
    outline-offset: 4px;
  }
  .spellbound-chakra__node[aria-pressed='true']:focus-visible {
    outline: 2px solid var(--spellbound-gold);
    outline-offset: 3px;
  }

  /* ---- Node tooltips (pill with name + colour dot) ---- */
  .spellbound-chakra__tip {
    position: absolute;
    bottom: calc(100% + 0.6rem);
    left: 50%;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.32rem 0.75rem;
    border-radius: 999px;
    background: var(--spellbound-surface-2);
    border: 1px solid var(--spellbound-border-strong);
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--spellbound-text-soft);
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transform: translate(-50%, 6px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
  }
  .spellbound-chakra__tip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--chakra-colour, var(--spellbound-gold));
    flex: none;
  }
  .spellbound-chakra__node:focus-visible .spellbound-chakra__tip {
    opacity: 1;
    visibility: visible;
    transform: translate(-50%, 0);
  }
  @media (hover: hover) {
    .spellbound-chakra__node:hover .spellbound-chakra__tip {
      opacity: 1;
      visibility: visible;
      transform: translate(-50%, 0);
    }
  }
  @media (min-width: 1024px) {
    .spellbound-chakra__tip {
      bottom: auto;
      top: 50%;
      left: calc(100% + 0.75rem);
      transform: translate(-6px, -50%);
    }
    .spellbound-chakra__node:focus-visible .spellbound-chakra__tip {
      transform: translate(0, -50%);
    }
  }
  @media (min-width: 1024px) and (hover: hover) {
    .spellbound-chakra__node:hover .spellbound-chakra__tip {
      transform: translate(0, -50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .spellbound-chakra__node,
    .spellbound-chakra__tip {
      transition: none;
    }
    .spellbound-chakra__node.is-attuned::before,
    .spellbound-chakra__node.is-attuned::after {
      animation: none;
    }
  }

  /* ---- Detail area ---- */
  .spellbound-chakra__detail {
    text-align: center;
    max-width: 22rem;
    min-height: 8.5rem;
  }
  .spellbound-chakra__detail-name {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
    margin: 0 0 0.75rem;
  }
  .spellbound-chakra__detail-title {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .spellbound-chakra__detail-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--chakra-colour, var(--spellbound-gold));
    box-shadow: 0 0 10px 0 var(--chakra-colour, var(--spellbound-gold));
    flex: none;
  }
  .spellbound-chakra__detail-sanskrit {
    font-family: var(--font-accent--family);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--spellbound-text);
  }
  .spellbound-chakra__detail-en {
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--spellbound-gold);
  }
  .spellbound-chakra__detail-meaning {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--spellbound-text-soft);
  }
  .spellbound-chakra__detail-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.15rem;
    padding: 0.55rem 1.15rem;
    border: 1px solid var(--spellbound-border-strong);
    border-radius: 999px;
    background: transparent;
    text-decoration: none;
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--spellbound-gold);
    transition: border-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease;
  }
  .spellbound-chakra__detail-link:hover {
    border-color: var(--spellbound-gold-deep);
    color: var(--spellbound-gold-bright);
    box-shadow: 0 0 16px 0 var(--spellbound-gold-glow);
  }
  .spellbound-chakra__detail-link:focus-visible {
    outline: 2px solid var(--spellbound-gold);
    outline-offset: 3px;
  }
  .spellbound-chakra__detail-link[hidden] { display: none; }
  @media (prefers-reduced-motion: reduce) {
    .spellbound-chakra__detail-link { transition: none; }
  }

  /* ---- Main column (right) ---- */
  .spellbound-chakra__main { flex: 1; min-width: 0; }
  .spellbound-chakra__eyebrow {
    margin: 0 0 1.25rem;
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: var(--spellbound-gold);
  }
  .spellbound-chakra__heading {
    margin: 0 0 1.25rem;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight, 300);
    font-size: clamp(2.4rem, 4vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--spellbound-text);
  }
  .spellbound-chakra__heading em {
    font-family: var(--font-accent--family);
    font-style: italic;
    color: var(--spellbound-gold-bright);
  }
  .spellbound-chakra__copy {
    margin: 0 0 3rem;
    max-width: 38rem;
    font-family: var(--font-body--family);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--spellbound-text-soft);
  }

  /* ---- Kindred artifacts ---- */
  .spellbound-chakra__kindred-label {
    margin: 0 0 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--spellbound-gold-deep);
    font-family: var(--font-body--family);
    font-weight: 600;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--spellbound-gold);
  }
  .spellbound-chakra__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .spellbound-chakra__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 2rem;
    }
  }
  .spellbound-chakra__card {
    display: block;
    text-decoration: none;
  }
  .spellbound-chakra__card-media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--spellbound-surface);
    border: 1px solid var(--spellbound-border);
    margin-bottom: 1rem;
  }
  .spellbound-chakra__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-chakra__card:hover .spellbound-chakra__card-media img {
    transform: scale(1.03);
  }
  .spellbound-chakra__card-media::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    background: var(--spellbound-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-chakra__card:hover .spellbound-chakra__card-media::after {
    transform: scaleX(1);
  }
  .spellbound-chakra__card-badges {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.35rem;
  }
  .spellbound-chakra__card-title {
    margin: 0 0 0.25rem;
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight, 300);
    font-size: 1.2rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--spellbound-text);
    transition: color 0.3s ease;
  }
  .spellbound-chakra__card:hover .spellbound-chakra__card-title {
    color: var(--spellbound-gold-bright);
  }
  .spellbound-chakra__card-price {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: var(--spellbound-text-soft);
  }
  .spellbound-chakra__kindred-empty {
    margin: 0;
    padding: 1.25rem 0;
    font-family: var(--font-accent--family);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--spellbound-text-soft);
  }
  @media (prefers-reduced-motion: reduce) {
    .spellbound-chakra__card-media img,
    .spellbound-chakra__card-media::after,
    .spellbound-chakra__card-title {
      transition: none;
    }
  }
</style>

<section class="spellbound-chakra" data-spellbound-chakra aria-label="Chakra attunement">
  <div class="spellbound-chakra__atmos" aria-hidden="true">
    <img
      src="{{ 'spellbound-img-oracle.jpg' | asset_url }}"
      alt=""
      loading="lazy"
      width="968"
      height="516"
    >
  </div>
  <div class="spellbound-chakra__layout">

    <div class="spellbound-chakra__aside" data-spellbound-reveal>
      <div class="spellbound-chakra__nodes" role="group" aria-label="The seven chakras">
        {%- for slug in node_slugs -%}
          {%- assign i = forloop.index0 -%}
          {%- assign wrapped = '|' | append: node_keys[i] | append: '|' -%}
          {%- assign is_attuned = false -%}
          {%- if chakra_keys contains wrapped -%}
            {%- assign is_attuned = true -%}
          {%- endif -%}
          <button
            type="button"
            class="spellbound-chakra__node{% if is_attuned %} is-attuned{% endif %}"
            style="--chakra-colour: {{ node_colours[i] }};"
            data-chakra-node
            data-chakra-en="{{ node_en[i] | escape }}"
            data-chakra-sa="{{ node_sa[i] | escape }}"
            data-chakra-meaning="{{ node_meanings[i] | escape }}"
            data-chakra-colour="{{ node_colours[i] }}"
            data-chakra-url="{{ routes.collections_url }}/{{ slug }}-chakra"
            aria-pressed="{% if i == default_index %}true{% else %}false{% endif %}"
            aria-label="{{ node_en[i] }} chakra — {{ node_sa[i] }}"
          >
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round" aria-hidden="true" focusable="false">
              <circle cx="12" cy="12" r="3"></circle>
              <path d="M12 3.2c1.6 1.8 1.6 4 0 5.6-1.6-1.6-1.6-3.8 0-5.6Z"></path>
              <path d="M12 3.2c1.6 1.8 1.6 4 0 5.6-1.6-1.6-1.6-3.8 0-5.6Z" transform="rotate(60 12 12)"></path>
              <path d="M12 3.2c1.6 1.8 1.6 4 0 5.6-1.6-1.6-1.6-3.8 0-5.6Z" transform="rotate(120 12 12)"></path>
              <path d="M12 3.2c1.6 1.8 1.6 4 0 5.6-1.6-1.6-1.6-3.8 0-5.6Z" transform="rotate(180 12 12)"></path>
              <path d="M12 3.2c1.6 1.8 1.6 4 0 5.6-1.6-1.6-1.6-3.8 0-5.6Z" transform="rotate(240 12 12)"></path>
              <path d="M12 3.2c1.6 1.8 1.6 4 0 5.6-1.6-1.6-1.6-3.8 0-5.6Z" transform="rotate(300 12 12)"></path>
            </svg>
            <span class="spellbound-chakra__tip" aria-hidden="true">
              <span class="spellbound-chakra__tip-dot"></span>{{ node_en[i] }}
            </span>
          </button>
        {%- endfor -%}
      </div>

      <div
        class="spellbound-chakra__detail"
        data-chakra-detail
        aria-live="polite"
        {% if default_index >= 0 %}style="--chakra-colour: {{ node_colours[default_index] }};"{% endif %}
      >
        <p class="spellbound-chakra__detail-name">
          <span class="spellbound-chakra__detail-title">
            <span class="spellbound-chakra__detail-dot" aria-hidden="true"></span>
            {%- if default_index >= 0 -%}
              <span class="spellbound-chakra__detail-sanskrit" data-detail-sanskrit>{{ node_sa[default_index] }}</span>
            {%- else -%}
              <span class="spellbound-chakra__detail-sanskrit" data-detail-sanskrit>{{ active_display | escape }}</span>
            {%- endif -%}
          </span>
          {%- if default_index >= 0 -%}
            <span class="spellbound-chakra__detail-en" data-detail-en>{{ node_en[default_index] }}</span>
          {%- else -%}
            <span class="spellbound-chakra__detail-en" data-detail-en>Chakra</span>
          {%- endif -%}
        </p>
        <p class="spellbound-chakra__detail-meaning" data-detail-meaning>
          {%- if default_index >= 0 -%}
            {{- node_meanings[default_index] -}}
          {%- else -%}
            Choose a light on the column to read its meaning.
          {%- endif -%}
        </p>
        {%- if default_index >= 0 -%}
          <a
            class="spellbound-chakra__detail-link"
            data-detail-link
            href="{{ routes.collections_url }}/{{ node_slugs[default_index] }}-chakra"
          >
            <span>Explore <span data-detail-link-name>{{ node_en[default_index] }}</span> pieces</span>
            <span aria-hidden="true">&rarr;</span>
          </a>
        {%- else -%}
          <a
            class="spellbound-chakra__detail-link"
            data-detail-link
            href="{{ routes.collections_url }}"
            hidden
          >
            <span>Explore <span data-detail-link-name></span> pieces</span>
            <span aria-hidden="true">&rarr;</span>
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="spellbound-chakra__main" data-spellbound-reveal-group>
      <p class="spellbound-chakra__eyebrow">Chakra Attunement</p>
      <h2 class="spellbound-chakra__heading">Attuning the <em>{{ active_display | escape }}</em></h2>
      <p class="spellbound-chakra__copy">
        {{ active_display | escape }} energy runs through this piece. Trace the column of seven lights,
        choose any chakra to read its meaning, and meet the kindred artifacts below that share this attunement.
      </p>

      <div class="spellbound-chakra__kindred">
        <p class="spellbound-chakra__kindred-label">Kindred Artifacts</p>

        {%- assign kindred_count = 0 -%}
        {%- capture kindred_cards -%}
          {%- if section.settings.collection != blank -%}
            {%- for kindred_product in section.settings.collection.products -%}
              {%- if kindred_count >= 3 -%}{%- break -%}{%- endif -%}
              {%- unless kindred_product.id == product.id -%}
                {%- capture kindred_chakra -%}{%- render 'spellbound-metafield-value', value: kindred_product.metafields.custom.chakra -%}{%- endcapture -%}
                {%- assign kindred_chakra = kindred_chakra | strip | downcase -%}
                {%- if kindred_chakra != blank -%}
                  {%- assign kindred_values = kindred_chakra | split: ',' -%}
                  {%- assign kindred_matched = false -%}
                  {%- for kindred_value in kindred_values -%}
                    {%- assign kindred_key = kindred_value | replace: 'chakra', '' | strip | replace: ' ', '' | replace: '-', '' | replace: '_', '' -%}
                    {%- if kindred_key != '' -%}
                      {%- assign kindred_wrapped = '|' | append: kindred_key | append: '|' -%}
                      {%- if chakra_keys contains kindred_wrapped -%}
                        {%- assign kindred_matched = true -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if kindred_matched -%}
                    {%- assign kindred_count = kindred_count | plus: 1 -%}
                    <a href="{{ kindred_product.url }}" class="spellbound-chakra__card">
                      <div class="spellbound-chakra__card-media">
                        {%- if kindred_product.featured_image -%}
                          <img
                            src="{{ kindred_product.featured_image | image_url: width: 600 }}"
                            alt="{{ kindred_product.featured_image.alt | default: kindred_product.title | escape }}"
                            width="{{ kindred_product.featured_image.width }}"
                            height="{{ kindred_product.featured_image.height }}"
                            loading="lazy"
                          >
                        {%- endif -%}
                        <div class="spellbound-chakra__card-badges">
                          {% render 'spellbound-badges', product: kindred_product %}
                        </div>
                      </div>
                      <h3 class="spellbound-chakra__card-title">{{ kindred_product.title | escape }}</h3>
                      <p class="spellbound-chakra__card-price">{{ kindred_product.price | money }}</p>
                    </a>
                  {%- endif -%}
                {%- endif -%}
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endcapture -%}

        {%- if kindred_count > 0 -%}
          <div class="spellbound-chakra__grid" data-spellbound-reveal-group>
            {{ kindred_cards }}
          </div>
        {%- else -%}
          <p class="spellbound-chakra__kindred-empty">No kindred artifacts attuned to this chakra&hellip; yet.</p>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<script>
  (function () {
    function initChakraSection(sectionEl) {
      if (!sectionEl || sectionEl.dataset.chakraInit === 'true') return;
      sectionEl.dataset.chakraInit = 'true';

      var nodes = sectionEl.querySelectorAll('[data-chakra-node]');
      var detail = sectionEl.querySelector('[data-chakra-detail]');
      if (!nodes.length || !detail) return;

      var sanskritEl = detail.querySelector('[data-detail-sanskrit]');
      var englishEl = detail.querySelector('[data-detail-en]');
      var meaningEl = detail.querySelector('[data-detail-meaning]');
      var linkEl = detail.querySelector('[data-detail-link]');
      var linkNameEl = detail.querySelector('[data-detail-link-name]');

      function selectNode(button) {
        nodes.forEach(function (node) {
          node.setAttribute('aria-pressed', node === button ? 'true' : 'false');
        });
        var sanskrit = button.getAttribute('data-chakra-sa') || '';
        var english = button.getAttribute('data-chakra-en') || '';
        var meaning = button.getAttribute('data-chakra-meaning') || '';
        var colour = button.getAttribute('data-chakra-colour') || '';
        var url = button.getAttribute('data-chakra-url') || '';
        if (sanskritEl) sanskritEl.textContent = sanskrit;
        if (englishEl) englishEl.textContent = english;
        if (meaningEl) meaningEl.textContent = meaning;
        if (colour) detail.style.setProperty('--chakra-colour', colour);
        if (linkEl && url) {
          linkEl.href = url;
          if (linkNameEl) linkNameEl.textContent = english;
          linkEl.hidden = false;
        }
      }

      nodes.forEach(function (node) {
        node.addEventListener('click', function () {
          selectNode(node);
        });
      });
    }

    function initAll(root) {
      var scope = root && root.querySelectorAll ? root : document;
      scope.querySelectorAll('[data-spellbound-chakra]').forEach(initChakraSection);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll(document);
      });
    } else {
      initAll(document);
    }

    if (!window.__spellboundChakraBound) {
      window.__spellboundChakraBound = true;
      document.addEventListener('shopify:section:load', function (event) {
        initAll(event.target);
      });
    }
  })();
</script>

{%- endif -%}

{% schema %}
{
  "name": "Spellbound Chakra",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Source collection",
      "info": "Kindred artifacts sharing the product's chakra metafield are drawn from this collection"
    }
  ],
  "presets": [
    {
      "name": "Spellbound Chakra"
    }
  ]
}
{% endschema %}
