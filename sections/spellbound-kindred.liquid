{% comment %}
  Spellbound Kindred - reusable related-products strip driven by a shared
  correspondence metafield (intention / zodiac / element / theme / handmade).
  Matches ANY shared value, case-insensitive, list-aware on both sides via
  snippets/spellbound-metafield-value. Renders nothing when there are no
  matches (optional bonus section - no empty state).
  Candlelight tokens only (no hardcoded accent hex).
{% endcomment %}

{%- liquid
  assign match_field = section.settings.match_field | default: 'intention'
  assign max_products = section.settings.max_products | default: 4
  assign pool = section.settings.collection
  if pool == blank or pool.products.size == 0
    assign pool = collections['all']
  endif
  assign matched_count = 0
  assign eligible = false
-%}

{%- if match_field == 'handmade' -%}
  {%- assign current_handmade = product.metafields.custom.handmade.value | append: '' | downcase | strip -%}
  {%- if current_handmade == 'true' -%}
    {%- assign eligible = true -%}
  {%- endif -%}
{%- else -%}
  {%- capture current_raw -%}{%- render 'spellbound-metafield-value', value: product.metafields.custom[match_field] -%}{%- endcapture -%}
  {%- assign current_raw = current_raw | strip -%}
  {%- if current_raw != blank -%}
    {%- assign eligible = true -%}
    {%- assign current_values = current_raw | downcase | split: ',' -%}
  {%- endif -%}
{%- endif -%}

{%- if eligible and pool != blank -%}
  {%- capture kindred_cards -%}
    {%- for p in pool.products limit: 50 -%}
      {%- if matched_count >= max_products -%}
        {%- break -%}
      {%- endif -%}
      {%- if p.id == product.id -%}
        {%- continue -%}
      {%- endif -%}

      {%- assign is_match = false -%}
      {%- if match_field == 'handmade' -%}
        {%- assign p_handmade = p.metafields.custom.handmade.value | append: '' | downcase | strip -%}
        {%- if p_handmade == 'true' -%}
          {%- assign is_match = true -%}
        {%- endif -%}
      {%- else -%}
        {%- capture p_raw -%}{%- render 'spellbound-metafield-value', value: p.metafields.custom[match_field] -%}{%- endcapture -%}
        {%- assign p_raw = p_raw | strip -%}
        {%- if p_raw != blank -%}
          {%- assign p_values = p_raw | downcase | split: ',' -%}
          {%- for pv in p_values -%}
            {%- assign pv_clean = pv | strip -%}
            {%- if pv_clean == blank -%}
              {%- continue -%}
            {%- endif -%}
            {%- for cv in current_values -%}
              {%- assign cv_clean = cv | strip -%}
              {%- if cv_clean != blank and cv_clean == pv_clean -%}
                {%- assign is_match = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if is_match -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}

      {%- if is_match -%}
        {%- assign matched_count = matched_count | plus: 1 -%}
        {% render 'product-card', product: p, mode: 'editorial' %}
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}
{%- endif -%}

{%- if matched_count > 0 -%}
  <style>
    .spellbound-kindred {
      padding: clamp(4rem, 8vw, 7rem) 1.5rem;
      background: var(--spellbound-bg);
    }
    .spellbound-kindred__inner {
      max-width: 100rem;
      margin: 0 auto;
    }
    .spellbound-kindred__header {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      margin-bottom: clamp(var(--spellbound-space-8), 5vw, var(--spellbound-space-16));
    }
    .spellbound-kindred__title {
      font-family: var(--spellbound-type-display-family);
      font-weight: 400;
      font-size: var(--spellbound-type-section-title-size);
      color: var(--spellbound-text);
      line-height: 1.05;
      margin: 0;
    }
    .spellbound-kindred__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2.5rem 1rem;
    }
    @media (min-width: 990px) {
      .spellbound-kindred__grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 3rem 2rem;
      }
    }
  </style>

  <section class="spellbound-kindred">
    <div class="spellbound-kindred__inner">
      <div class="spellbound-kindred__header" data-spellbound-reveal>
        {%- if section.settings.heading != blank -%}
          <h2 class="spellbound-kindred__title">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
      <div class="spellbound-kindred__grid" data-spellbound-reveal-group>
        {{ kindred_cards }}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Spellbound Kindred",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Cut from the same cloth"
    },
    {
      "type": "select",
      "id": "match_field",
      "label": "Match by",
      "options": [
        { "value": "intention", "label": "Intention" },
        { "value": "zodiac", "label": "Zodiac" },
        { "value": "element", "label": "Ruling element" },
        { "value": "theme", "label": "Theme" },
        { "value": "handmade", "label": "Handmade" }
      ],
      "default": "intention"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Source pool for matches; falls back to all products."
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Spellbound Kindred"
    }
  ]
}
{% endschema %}
