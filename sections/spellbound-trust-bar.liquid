{% comment %}
  Spellbound Trust Bar - slim row of reassurance signals (hand-packed,
  secure checkout, independent shop, real help). Sits under the hero to
  answer "can I trust this shop?" before the buying path starts.
  All claims are factual: no invented shipping promises.
{% endcomment %}

<style>
  .spellbound-trust {
    background: var(--spellbound-surface, #1a1a1a);
    border-top: 1px solid var(--spellbound-border, rgba(212, 175, 55, 0.18));
    border-bottom: 1px solid var(--spellbound-border, rgba(212, 175, 55, 0.18));
    padding-inline: 1.25rem;
  }
  .spellbound-trust__grid {
    position: relative;
    max-width: 42rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    padding-block: 0.75rem;
  }
  .spellbound-trust__grid::before {
    content: '';
    position: absolute;
    z-index: 0;
    top: 2.75rem;
    bottom: 2.75rem;
    left: 1.125rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      rgba(212, 175, 55, 0),
      var(--spellbound-gold, #d4af37) 12%,
      var(--spellbound-gold, #d4af37) 88%,
      rgba(212, 175, 55, 0)
    );
    opacity: 0;
    transform: scaleY(0);
    transform-origin: top;
    transition:
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-trust__grid.is-visible::before,
  .no-js .spellbound-trust__grid::before {
    opacity: 0.58;
    transform: scaleY(1);
  }
  .spellbound-trust__item {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 2.25rem minmax(0, 1fr);
    align-items: center;
    gap: 1rem;
    min-width: 0;
    min-height: 60px;
    padding: 0.4rem 0;
    color: var(--spellbound-text, #f7f1e3);
    text-decoration: none;
  }
  .spellbound-trust__icon {
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0.5rem;
    border: 1px solid rgba(212, 175, 55, 0.58);
    border-radius: 50%;
    background: var(--spellbound-surface, #1a1a1a);
    color: var(--spellbound-gold, #d4af37);
    transition:
      transform 220ms cubic-bezier(0.16, 1, 0.3, 1),
      border-color 220ms cubic-bezier(0.16, 1, 0.3, 1),
      color 220ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .spellbound-trust__icon svg {
    width: 100%;
    height: 100%;
  }
  .spellbound-trust__title {
    margin: 0 0 0.15rem;
    font-family: var(--spellbound-type-reading-family);
    font-size: 1.125rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: 0.015em;
    color: var(--spellbound-text, #f7f1e3);
  }
  .spellbound-trust__text {
    margin: 0;
    font-family: var(--spellbound-type-reading-family);
    font-size: 1rem;
    line-height: 1.45;
    color: var(--spellbound-text-soft, rgba(247, 241, 227, 0.78));
  }
  a.spellbound-trust__item:hover .spellbound-trust__title {
    color: var(--spellbound-gold-bright, #e6c55f);
  }
  a.spellbound-trust__item:hover .spellbound-trust__icon {
    border-color: var(--spellbound-gold-bright, #e6c55f);
    color: var(--spellbound-gold-bright, #e6c55f);
    transform: scale(1.05);
  }
  a.spellbound-trust__item:focus-visible {
    outline: 2px solid var(--spellbound-gold, #d4af37);
    outline-offset: 3px;
  }

  @media (min-width: 1100px) {
    .spellbound-trust {
      padding-inline: 2rem;
    }
    .spellbound-trust__grid {
      max-width: 1320px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      padding-block: 1.75rem;
    }
    .spellbound-trust__grid::before {
      top: 2.875rem;
      right: 12.5%;
      bottom: auto;
      left: 12.5%;
      width: auto;
      height: 1px;
      background: linear-gradient(
        to right,
        rgba(212, 175, 55, 0),
        var(--spellbound-gold, #d4af37) 8%,
        var(--spellbound-gold, #d4af37) 92%,
        rgba(212, 175, 55, 0)
      );
      transform: scaleX(0);
      transform-origin: left;
    }
    .spellbound-trust__grid.is-visible::before,
    .no-js .spellbound-trust__grid::before {
      transform: scaleX(1);
    }
    .spellbound-trust__item {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: 0.75rem;
      min-height: 0;
      padding: 0 clamp(1.5rem, 2.5vw, 2.25rem);
      text-align: center;
    }
    .spellbound-trust__item > span:last-child {
      max-width: 15.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .spellbound-trust__grid::before,
    .spellbound-trust__grid.is-visible::before {
      opacity: 0.58;
      transform: none;
      transition: none;
    }
    .spellbound-trust__icon {
      transition: none;
    }
  }
</style>

<section class="spellbound-trust" aria-label="Why shop with Totally Spellbound">
  <div class="spellbound-trust__grid" data-spellbound-reveal-group>
    {%- for block in section.blocks -%}
      {%- if block.settings.link != blank -%}
        <a class="spellbound-trust__item" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>
      {%- else -%}
        <div class="spellbound-trust__item" {{ block.shopify_attributes }}>
      {%- endif -%}
      <span class="spellbound-trust__icon" aria-hidden="true">{{ block.settings.icon }}</span>
      <span>
        <p class="spellbound-trust__title">{{ block.settings.title | escape }}</p>
        <p class="spellbound-trust__text">{{ block.settings.text | escape }}</p>
      </span>
      {%- if block.settings.link != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Spellbound Trust Bar",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "signal",
      "name": "Trust signal",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Hand-packed with care"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Every order leaves our shop wrapped like a gift."
        },
        {
          "type": "html",
          "id": "icon",
          "label": "Icon (inline SVG)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Spellbound Trust Bar"
    }
  ]
}
{% endschema %}
