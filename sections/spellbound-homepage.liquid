<section class="spellbound-section spellbound-section--homepage">
  <div class="page-width">
    <h1>{{ section.settings.heading }}</h1>
    <p class="spellbound-label">{{ section.settings.subheading }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Homepage Skeleton",
  "class": "spellbound-homepage",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Totally Spellbound"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Crystals, curiosities & things that make you feel something"
    }
  ],
  "presets": [
    {
      "name": "Homepage Skeleton"
    }
  ]
}
{% endschema %}
