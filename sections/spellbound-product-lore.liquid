{% comment %}
  Spellbound Product Lore - Celestial Correspondence with Planetary Pairs products
{% endcomment %}

<style>
  .spellbound-lore {
    padding: 10rem 1.5rem;
    background: linear-gradient(to bottom, #050505, #000000);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    overflow: hidden;
  }
  @media (min-width: 1024px) {
    .spellbound-lore { padding: 10rem 6rem; }
  }
  .spellbound-lore__inner {
    max-width: 87.5rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 5rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .spellbound-lore__inner { grid-template-columns: 1fr 1fr; }
  }
  .spellbound-lore__label {
    color: #f59e0b;
    font-size: 10px;
    letter-spacing: 0.6em;
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    display: block;
  }
  .spellbound-lore__planet-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }
  .spellbound-lore__planet-icon {
    width: 6rem;
    height: 6rem;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.4);
    flex-shrink: 0;
  }
  .spellbound-lore__planet-icon svg { width: 40px; height: 40px; }
  .spellbound-lore__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(2.5rem, 4vw, 5rem);
    color: #ffffff;
    line-height: 1;
  }
  .spellbound-lore__heading em {
    font-family: var(--font-accent--family);
    font-style: italic;
  }
  .spellbound-lore__description {
    color: rgba(255,255,255,0.5);
    font-size: 1.125rem;
    line-height: 1.8;
    max-width: 32rem;
    margin-bottom: 3rem;
  }
  .spellbound-lore__explore {
    font-size: 10px;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 0.5rem;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .spellbound-lore__explore:hover { color: #ffffff; }

  /* Planetary Pairs sidebar */
  .spellbound-lore__pairs {
    background: rgba(255,255,255,0.05);
    padding: 2.5rem;
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(4px);
  }
  .spellbound-lore__pairs-title {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.4);
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .spellbound-lore__pairs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .spellbound-lore__pair-card {
    text-decoration: none;
    display: block;
  }
  .spellbound-lore__pair-card:hover .spellbound-lore__pair-title {
    color: #fde68a;
  }
  .spellbound-lore__pair-img {
    aspect-ratio: 1;
    background: #000;
    overflow: hidden;
    margin-bottom: 1rem;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .spellbound-lore__pair-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter 0.7s ease;
  }
  .spellbound-lore__pair-card:hover .spellbound-lore__pair-img img {
    filter: grayscale(0%);
  }
  .spellbound-lore__pair-title {
    color: #ffffff;
    font-family: var(--font-heading--family);
    font-size: 0.875rem;
    transition: color 0.3s ease;
    margin-bottom: 0.25rem;
  }
  .spellbound-lore__pair-price {
    font-size: 9px;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }
  .spellbound-lore__pairs-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 0;
    color: rgba(255,255,255,0.15);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.3em;
  }
</style>

{%- assign current_product = product -%}

{%- comment -%} Handle planet as array (list.single_line_text_field) {%- endcomment -%}
{%- assign planet_values = current_product.metafields.custom.planet.value -%}
{%- assign planet_clean = '' -%}
{%- if planet_values.size > 0 -%}
  {%- assign planet_names = '' -%}
  {%- for pv in planet_values -%}
    {%- assign pv_stripped = pv | strip -%}
    {%- if pv_stripped != blank -%}
      {%- if planet_names == '' -%}
        {%- assign planet_names = pv_stripped -%}
      {%- else -%}
        {%- assign planet_names = planet_names | append: ', ' | append: pv_stripped -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign planet_clean = planet_names -%}
{%- else -%}
  {%- capture planet_raw -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.planet -%}{%- endcapture -%}
  {%- assign planet_clean = planet_raw | strip -%}
  {%- if planet_clean != blank -%}
    {%- assign planet_values = planet_clean | split: ', ' -%}
  {%- endif -%}
{%- endif -%}

{%- capture element_clean -%}{%- render 'spellbound-metafield-value', value: current_product.metafields.custom.element -%}{%- endcapture -%}
{%- assign element_clean = element_clean | strip -%}

{% if planet_clean != blank or element_clean != blank %}
<section class="spellbound-lore">
  <div class="spellbound-lore__inner">
    <!-- Left: Planet info -->
    <div>
      <span class="spellbound-lore__label">Celestial Correspondence</span>

      {% if planet_clean != blank %}
        <div class="spellbound-lore__planet-header">
          <div class="spellbound-lore__planet-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/></svg>
          </div>
          <h2 class="spellbound-lore__heading">Under <em>{{ planet_clean }}</em></h2>
        </div>
      {% endif %}

      {% if section.settings.lore_description != blank %}
        <p class="spellbound-lore__description">{{ section.settings.lore_description }}</p>
      {% elsif planet_clean != blank %}
        <p class="spellbound-lore__description">
          This artifact resonates with the energy of {{ planet_clean }}, channeling its celestial influence into the material plane.
          {% if element_clean != blank %}Its {{ element_clean }} nature grounds this power in the tangible world.{% endif %}
        </p>
      {% endif %}

      {% if section.settings.explore_link != blank %}
        <a href="{{ section.settings.explore_link }}" class="spellbound-lore__explore">
          Explore All {{ planet_clean }} Artifacts
        </a>
      {% endif %}
    </div>

    <!-- Right: Planetary Pairs products -->
    <div class="spellbound-lore__pairs">
      <h3 class="spellbound-lore__pairs-title">Planetary Pairs</h3>
      <div class="spellbound-lore__pairs-grid">
        {%- assign pairs_count = 0 -%}

        {%- comment -%} Find products sharing any planet with current product {%- endcomment -%}
        {%- if section.settings.collection != blank and planet_values.size > 0 -%}
          {%- for related_product in collections[section.settings.collection].products -%}
            {%- if related_product.id == current_product.id -%}{%- continue -%}{%- endif -%}
            {%- if pairs_count >= 2 -%}{%- break -%}{%- endif -%}

            {%- assign related_planet_values = related_product.metafields.custom.planet.value -%}
            {%- assign has_match = false -%}

            {%- if related_planet_values.size > 0 -%}
              {%- for rp in related_planet_values -%}
                {%- assign rp_down = rp | strip | downcase -%}
                {%- for cp in planet_values -%}
                  {%- assign cp_down = cp | strip | downcase -%}
                  {%- if rp_down == cp_down -%}
                    {%- assign has_match = true -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- if has_match -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
            {%- else -%}
              {%- capture related_planet_raw -%}{%- render 'spellbound-metafield-value', value: related_product.metafields.custom.planet -%}{%- endcapture -%}
              {%- assign related_planet_raw = related_planet_raw | strip | downcase -%}
              {%- for cp in planet_values -%}
                {%- assign cp_down = cp | strip | downcase -%}
                {%- if related_planet_raw == cp_down -%}
                  {%- assign has_match = true -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}

            {%- if has_match -%}
              <a href="{{ related_product.url }}" class="spellbound-lore__pair-card">
                <div class="spellbound-lore__pair-img">
                  {% if related_product.featured_image %}
                    <img
                      src="{{ related_product.featured_image | image_url: width: 400 }}"
                      alt="{{ related_product.title | escape }}"
                      loading="lazy"
                      width="{{ related_product.featured_image.width }}"
                      height="{{ related_product.featured_image.height }}"
                    >
                  {% endif %}
                </div>
                <h4 class="spellbound-lore__pair-title">{{ related_product.title }}</h4>
                <span class="spellbound-lore__pair-price">{{ related_product.price | money }}</span>
              </a>
              {%- assign pairs_count = pairs_count | plus: 1 -%}
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}

        {%- if pairs_count == 0 -%}
          <div class="spellbound-lore__pairs-empty">
            No planetary pairs discovered yet
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Spellbound Product Lore",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "textarea",
      "id": "lore_description",
      "label": "Custom lore text",
      "info": "Leave blank for auto-generated description based on metafields"
    },
    {
      "type": "url",
      "id": "explore_link",
      "label": "Explore collection link",
      "info": "Link to browse more artifacts with the same planet"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Source collection for planetary pairs",
      "info": "Products with the same planet metafield will appear as Planetary Pairs"
    }
  ],
  "templates": ["product"],
  "presets": [
    {
      "name": "Spellbound Product Lore"
    }
  ]
}
{% endschema %}
