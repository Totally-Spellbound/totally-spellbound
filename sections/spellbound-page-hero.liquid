{% comment %}
  Spellbound Page Hero - compact cinematic page header for content pages.
  Dim cover backdrop (image picker with theme-asset fallback), scrim fading
  into the page background, gold micro-label, Cormorant page title, soft intro.
  Candlelight tokens only (no hardcoded accent hex).
{% endcomment %}

<style>
  .spellbound-page-hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: 300px;
    height: clamp(300px, 45vh, 480px);
    overflow: hidden;
    background: var(--spellbound-bg);
  }
  .spellbound-page-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .spellbound-page-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .spellbound-page-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(13, 11, 16, 0.55) 0%,
      rgba(13, 11, 16, 0.35) 40%,
      rgba(13, 11, 16, 0.72) 72%,
      var(--spellbound-bg) 100%
    );
  }
  .spellbound-page-hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 72rem;
    margin: 0 auto;
    padding: clamp(4.5rem, 10vw, 7rem) 1.5rem clamp(2rem, 5vw, 3.25rem);
  }
  .spellbound-page-hero__label {
    display: block;
    font-family: var(--font-body--family);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--spellbound-gold);
    margin-bottom: 1rem;
  }
  .spellbound-page-hero__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.05;
    color: var(--spellbound-text);
    margin: 0;
    text-wrap: balance;
  }
  .spellbound-page-hero__intro {
    font-family: var(--font-body--family);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--spellbound-text-soft);
    max-width: 40rem;
    margin: 1.125rem 0 0;
  }
</style>

<section class="spellbound-page-hero">
  <div class="spellbound-page-hero__media" aria-hidden="true">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: 1600 }}"
        srcset="{{ section.settings.image | image_url: width: 750 }} 750w, {{ section.settings.image | image_url: width: 1100 }} 1100w, {{ section.settings.image | image_url: width: 1600 }} 1600w"
        sizes="100vw"
        alt=""
        class="spellbound-page-hero__image"
        loading="eager"
        fetchpriority="high"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    {% elsif section.settings.image_asset != blank %}
      <img
        src="{{ section.settings.image_asset | asset_url }}"
        alt=""
        class="spellbound-page-hero__image"
        loading="eager"
        fetchpriority="high"
        width="968"
        height="545"
        onerror="this.style.visibility='hidden'"
      >
    {% endif %}
    <div class="spellbound-page-hero__scrim"></div>
  </div>

  <div class="spellbound-page-hero__content" data-spellbound-reveal-group>
    {% if section.settings.label != blank %}
      <span class="spellbound-page-hero__label">{{ section.settings.label | escape }}</span>
    {% endif %}
    {%- liquid
      assign hero_title = section.settings.title
      if page.title != blank
        assign hero_title = page.title
      endif
    -%}
    {% if hero_title != blank %}
      <h1 class="spellbound-page-hero__title">{{ hero_title | escape }}</h1>
    {% endif %}
    {% if section.settings.intro != blank %}
      <p class="spellbound-page-hero__intro">{{ section.settings.intro | escape }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Spellbound Page Hero",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Backdrop image"
    },
    {
      "type": "text",
      "id": "image_asset",
      "label": "Fallback image asset",
      "default": "spellbound-img-hero.jpg",
      "info": "Theme asset filename used when no image is picked."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Micro-label",
      "default": "Totally Spellbound"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Fallback title",
      "info": "Used when the page has no title (the page title wins)."
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro"
    }
  ],
  "presets": [
    {
      "name": "Spellbound Page Hero"
    }
  ]
}
{% endschema %}
