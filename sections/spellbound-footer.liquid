{% comment %}
  Spellbound Footer — full ecommerce footer: brand + social, explore links,
  visit info, newsletter, policies, payment icons, copyright.
  Brand Guidelines v1.0: Cinzel Decorative headings, Cormorant Garamond body,
  gold on #0d0b10 with purple accents.
{% endcomment %}

<style>
  .spellbound-footer {
    position: relative;
    background: linear-gradient(to bottom, var(--spellbound-bg), #08060b);
    padding: clamp(3rem, 6vw, 5rem) 1.5rem 7.5rem;
    color: var(--spellbound-text-soft);
  }
  .spellbound-footer__inner {
    max-width: 100rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 750px) {
    .spellbound-footer__inner {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 3.5rem 2.5rem;
    }
  }
  @media (min-width: 1200px) {
    .spellbound-footer__inner {
      grid-template-columns: 1.4fr 0.8fr 1fr 1.2fr;
      gap: 4rem;
    }
  }
  .spellbound-footer__logo {
    display: block;
    width: min(240px, 60vw);
    height: auto;
    margin-bottom: 1.5rem;
  }
  .spellbound-footer__blurb {
    font-size: 1rem;
    line-height: 1.8;
    max-width: 26rem;
    margin: 0 0 1.75rem;
  }
  .spellbound-footer__social {
    display: flex;
    gap: 0.875rem;
  }
  .spellbound-footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1px solid var(--spellbound-gold-deep);
    color: var(--spellbound-gold);
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }
  .spellbound-footer__social a:hover {
    background: var(--spellbound-gold);
    border-color: var(--spellbound-gold);
    color: var(--spellbound-bg);
  }
  .spellbound-footer__social svg {
    width: 18px;
    height: 18px;
  }
  .spellbound-footer__heading {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 1.125rem;
    letter-spacing: 0.08em;
    color: var(--spellbound-gold);
    margin: 0 0 1.5rem;
  }
  .spellbound-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .spellbound-footer__links a {
    font-size: 1.0625rem;
    color: var(--spellbound-text-soft);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .spellbound-footer__links a:hover {
    color: var(--spellbound-gold-bright);
  }
  .spellbound-footer__info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 1.0625rem;
    line-height: 1.7;
  }
  .spellbound-footer__info-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    margin: 0;
  }
  .spellbound-footer__info-item svg {
    flex-shrink: 0;
    width: 17px;
    height: 17px;
    margin-top: 0.3em;
    color: var(--spellbound-gold);
  }
  .spellbound-footer__info-item a {
    color: var(--spellbound-text-soft);
    text-decoration: underline;
    text-decoration-color: var(--spellbound-gold-deep);
    text-underline-offset: 3px;
    transition: color 0.3s ease;
  }
  .spellbound-footer__info-item a:hover {
    color: var(--spellbound-gold-bright);
  }
  .spellbound-footer__news-text {
    font-size: 1rem;
    line-height: 1.7;
    margin: 0 0 1.25rem;
  }
  .spellbound-footer__form {
    display: flex;
    gap: 0.75rem;
    max-width: 26rem;
  }
  .spellbound-footer__form input[type='email'] {
    flex: 1;
    min-width: 0;
    padding: 0.9rem 1.3rem;
    background: rgba(247, 241, 227, 0.04);
    border: 1px solid var(--spellbound-border-strong);
    border-radius: 2px;
    outline: none;
    color: var(--spellbound-text);
    font-family: var(--font-body--family);
    font-size: 1rem;
    transition: border-color 0.3s ease;
  }
  .spellbound-footer__form input[type='email']:focus {
    border-color: var(--spellbound-gold);
  }
  .spellbound-footer__form input[type='email']::placeholder {
    color: var(--spellbound-text-faint);
  }
  .spellbound-footer__form button {
    padding: 0.9rem 1.75rem;
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .spellbound-footer__form-success {
    margin: 0.875rem 0 0;
    font-size: 1rem;
    color: var(--spellbound-gold-bright);
  }
  .spellbound-footer__form-error {
    margin: 0.875rem 0 0;
    font-size: 1rem;
    color: #e08f8f;
  }
  .spellbound-footer__bottom {
    max-width: 100rem;
    margin: clamp(3rem, 6vw, 4.5rem) auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--spellbound-border);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    text-align: center;
  }
  @media (min-width: 990px) {
    .spellbound-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
  .spellbound-footer__policies {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.75rem;
  }
  .spellbound-footer__policies a {
    font-size: 0.9375rem;
    color: var(--spellbound-text-faint);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .spellbound-footer__policies a:hover {
    color: var(--spellbound-gold-bright);
  }
  .spellbound-footer__payments {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }
  .spellbound-footer__payments svg {
    height: 24px;
    width: auto;
    opacity: 0.75;
  }
  .spellbound-footer__copyright {
    font-size: 0.9375rem;
    color: var(--spellbound-text-faint);
    margin: 0;
  }
  .spellbound-footer__cat {
    position: absolute;
    bottom: -14px;
    left: 50%;
    translate: -50% 0;
    display: flex;
    line-height: 0;
    pointer-events: none;
  }
  .spellbound-cat-z {
    transform-box: fill-box;
    transform-origin: center;
    opacity: 0;
    animation: spellbound-cat-snore 3.6s ease-in-out infinite;
  }
  .spellbound-cat-z--2 {
    animation-delay: 1.8s;
  }
  @keyframes spellbound-cat-snore {
    0% {
      opacity: 0;
      transform: translate(-4px, 10px) scale(0.7);
    }
    20% {
      opacity: 0.85;
    }
    65% {
      opacity: 0.7;
    }
    100% {
      opacity: 0;
      transform: translate(10px, -22px) scale(1.15);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .spellbound-cat-z {
      animation: none;
      opacity: 0.85;
      transform: none;
    }
  }
  .spellbound-footer__cat svg {
    width: 170px;
    height: auto;
    display: block;
  }
</style>

{% render 'spellbound-ornament' %}
<footer class="spellbound-footer">
  <div class="spellbound-footer__inner">
    <div>
      <img
        src="{{ 'spellbound-logo-banner.png' | asset_url }}"
        alt="{{ shop.name | escape }}"
        class="spellbound-footer__logo"
        width="480"
        height="240"
        loading="lazy"
      >
      <p class="spellbound-footer__blurb">{{ section.settings.blurb }}</p>
      <div class="spellbound-footer__social">
        {% if section.settings.facebook_url != blank %}
          <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Totally Spellbound on Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.2h-3.1V7.7c0-.9.3-1.6 1.6-1.6h1.7V3.2c-.3 0-1.3-.1-2.5-.1-2.5 0-4.2 1.5-4.2 4.3v2.4H7.4V13h2.7v8h3.4Z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.instagram_url != blank %}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Totally Spellbound on Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3.2" y="3.2" width="17.6" height="17.6" rx="4.6"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg>
          </a>
        {% endif %}
        {% if section.settings.tiktok_url != blank %}
          <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener" aria-label="Totally Spellbound on TikTok">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16.6 3c.3 1.9 1.5 3.4 3.4 3.7v3.1c-1.3 0-2.5-.4-3.4-1v6.4c0 3.4-2.4 5.8-5.6 5.8A5.6 5.6 0 0 1 5.4 15c0-3.2 2.5-5.6 5.8-5.5v3.2c-1.5-.2-2.7.8-2.7 2.3 0 1.4 1 2.4 2.4 2.4 1.5 0 2.5-1 2.5-2.7V3h3.2Z"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <nav aria-label="Footer navigation">
      <h2 class="spellbound-footer__heading">Explore</h2>
      <ul class="spellbound-footer__links">
        {% assign footer_menu = linklists[section.settings.menu] %}
        {% if footer_menu != blank and footer_menu.links.size > 0 %}
          {% for link in footer_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        {% else %}
          <li><a href="{{ routes.all_products_collection_url }}">Shop All</a></li>
          <li><a href="/pages/our-story">Our Story</a></li>
          <li><a href="/pages/visit-us">Visit Us</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        {% endif %}
      </ul>
    </nav>

    <div>
      <h2 class="spellbound-footer__heading">The Shop</h2>
      <div class="spellbound-footer__info">
        <p class="spellbound-footer__info-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><path d="M12 21s-7-5.2-7-11a7 7 0 0 1 14 0c0 5.8-7 11-7 11Z"/><circle cx="12" cy="10" r="2.6"/></svg>
          <span>{{ section.settings.address }}</span>
        </p>
        <p class="spellbound-footer__info-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><circle cx="12" cy="12" r="8.6"/><path d="M12 7.5V12l3 2"/></svg>
          <span>{{ section.settings.hours }}</span>
        </p>
        {% if section.settings.email != blank %}
          <p class="spellbound-footer__info-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="3.2" y="5.2" width="17.6" height="13.6" rx="2.4"/><path d="m4 7 8 6 8-6"/></svg>
            <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
          </p>
        {% endif %}
      </div>
    </div>

    <div>
      <h2 class="spellbound-footer__heading">Join the Coven</h2>
      <p class="spellbound-footer__news-text">{{ section.settings.newsletter_text }}</p>
      {% form 'customer', class: 'spellbound-footer__form-wrap' %}
        {% if form.posted_successfully? %}
          <p class="spellbound-footer__form-success">Welcome to the coven — you're on the list.</p>
        {% else %}
          <div class="spellbound-footer__form">
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input
              type="email"
              name="contact[email]"
              placeholder="Your email address"
              autocomplete="email"
              required
              aria-label="Email address"
            >
            <button type="submit">Join</button>
          </div>
          {% if form.errors %}
            <p class="spellbound-footer__form-error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
          {% endif %}
        {% endif %}
      {% endform %}
    </div>
  </div>

  <div class="spellbound-footer__bottom">
    <ul class="spellbound-footer__policies">
      {% if shop.privacy_policy != blank %}<li><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>{% endif %}
      {% if shop.refund_policy != blank %}<li><a href="{{ shop.refund_policy.url }}">Refund Policy</a></li>{% endif %}
      {% if shop.shipping_policy != blank %}<li><a href="{{ shop.shipping_policy.url }}">Shipping Policy</a></li>{% endif %}
      {% if shop.terms_of_service != blank %}<li><a href="{{ shop.terms_of_service.url }}">Terms of Service</a></li>{% endif %}
    </ul>
    <div class="spellbound-footer__payments" aria-label="Accepted payment methods">
      {% for type in shop.enabled_payment_types %}
        {{ type | payment_type_svg_tag }}
      {% endfor %}
    </div>
    <p class="spellbound-footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
  </div>

  <div class="spellbound-footer__cat" aria-hidden="true" title="The shop cat is asleep">
    <svg viewBox="0 0 506 295" xmlns="http://www.w3.org/2000/svg">
      <g filter="url(#spellbound-cat-glow)">
        <path d="M8 78 L12 105 L34 158 L36 190 L47 212 L38 224 L37 238 L46 247 L49 235 L54 251 L65 251 L71 232 L97 216 L48 217 L65 209 L123 216 L84 228 L72 242 L71 251 L76 258 L80 258 L84 244 L86 258 L93 260 L97 245 L98 257 L103 261 L126 259 L127 244 L139 227 L158 215 L186 207 L229 207 L337 230 L374 229 L409 219 L379 234 L340 236 L239 216 L193 214 L154 225 L139 237 L133 249 L136 268 L169 285 L224 294 L316 295 L369 288 L411 274 L442 249 L453 230 L458 206 L456 181 L438 135 L405 95 L354 65 L318 56 L280 55 L247 61 L210 77 L206 104 L220 127 L218 154 L214 126 L200 107 L200 57 L191 30 L182 31 L165 42 L134 71 L110 73 L82 85 L32 72 L15 72 Z" fill="#1d1724"/>
      </g>
      <path d="M123 189 L122 192 L118 195 L114 197 L107 199 L98 199 L92 197 L90 196 L89 191 L94 192 L99 194 L105 194 L112 192 L118 188 L121 187 Z" fill="#d4af37"/>
      <path d="M159 188 L159 190 L158 193 L154 201 L153 202 L147 202 L141 199 L139 197 L138 197 L137 195 L144 189 L148 187 L151 186 L157 186 Z" fill="#d4af37"/>
      <path d="M231 174 L231 177 L220 182 L201 188 L195 188 L200 184 L212 178 L218 176 Z" fill="#d4af37"/>
      <path d="M236 156 L234 158 L222 166 L212 172 L200 178 L200 175 L207 169 L214 164 L219 161 L230 156 L233 155 Z" fill="#d4af37"/>
      <path d="M191 151 L192 157 L190 161 L182 169 L173 173 L164 172 L164 170 L166 168 L169 167 L172 167 L180 163 L184 160 L187 157 Z" fill="#d4af37"/>
      <path d="M331 120 L303 128 L280 142 L266 156 L255 172 L248 188 L244 202 L244 187 L251 167 L263 149 L274 138 L285 130 L306 121 L315 119 Z" fill="rgba(212,175,55,0.45)"/>
      <path d="M23 86 L33 88 L46 94 L59 103 L66 111 L53 126 L49 132 L46 139 L44 141 L39 134 L30 114 L24 96 L22 88 Z" fill="rgba(212,175,55,0.75)"/>
      <path d="M186 44 L188 46 L190 54 L192 72 L190 100 L182 94 L170 89 L164 88 L163 82 L168 71 L175 58 L184 45 Z" fill="rgba(212,175,55,0.75)"/>
      <g stroke="#d4af37" stroke-width="6" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path class="spellbound-cat-z" d="M79 60 h18 l-18 18 h18"/>
        <path class="spellbound-cat-z spellbound-cat-z--2" d="M109 34 h24 l-24 24 h24"/>
      </g>
      <defs>
        <filter id="spellbound-cat-glow" x="-15%" y="-15%" width="130%" height="130%">
          <feDropShadow dx="0" dy="0" stdDeviation="7" flood-color="#d4af37" flood-opacity="0.28"/>
        </filter>
      </defs>
    </svg>
  </div>
</footer>

{% schema %}
{
  "name": "Spellbound Footer",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "textarea",
      "id": "blurb",
      "label": "Brand blurb",
      "default": "A real little crystal and curiosity shop in Sutton-in-Ashfield. Every crystal, deck and charm is chosen by hand — and packed with the same care as if you'd walked through the door."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Address",
      "default": "108 Outram Street, Sutton-in-Ashfield NG17 4FS"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Opening hours",
      "default": "Mon–Sat 10am–4pm · Closed Sundays"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Contact email"
    },
    {
      "type": "textarea",
      "id": "newsletter_text",
      "label": "Newsletter text",
      "default": "Receive transmissions about new arrivals, rituals and exclusive offerings. No noise — just magic."
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "presets": [
    {
      "name": "Spellbound Footer"
    }
  ]
}
{% endschema %}
