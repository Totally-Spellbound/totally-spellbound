{% comment %}
  Spellbound Featured Products - "New Manifestations" product grid with custom cards
{% endcomment %}

<style>
  .spellbound-featured {
    padding: 8rem 1.5rem;
    background: #000000;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .spellbound-featured__inner {
    max-width: 100rem;
    margin: 0 auto;
  }
  .spellbound-featured__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 5rem;
  }
  .spellbound-featured__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(2.5rem, 4vw, 6rem);
    color: #ffffff;
    line-height: 1;
  }
  .spellbound-featured__view-all {
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 0.25rem;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  .spellbound-featured__view-all:hover {
    color: #ffffff;
  }
  .spellbound-featured__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 2rem;
  }
  @media (min-width: 768px) {
    .spellbound-featured__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .spellbound-featured__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 2rem 2rem;
    }
  }

  /* Product Card Styles */
  .spellbound-product-card {
    cursor: pointer;
    text-decoration: none;
    display: block;
  }
  .spellbound-product-card__media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #0d0d0d;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
  }
  .spellbound-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: all 1.5s ease;
  }
  .spellbound-product-card:hover .spellbound-product-card__image {
    filter: grayscale(0%);
    transform: scale(1.05);
  }
  .spellbound-product-card__badges {
    position: absolute;
    top: 1rem;
    left: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    z-index: 1;
  }
  .spellbound-product-card__badge {
    font-size: 8px;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(8px);
    padding: 4px 8px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.8);
  }
  .spellbound-product-card__badge--amber {
    color: #fde68a;
  }
  .spellbound-product-card__info {
    text-align: center;
  }
  .spellbound-product-card__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: 1.25rem;
    color: #ffffff;
    letter-spacing: -0.03em;
    margin-bottom: 0.25rem;
    transition: color 0.3s ease;
  }
  .spellbound-product-card:hover .spellbound-product-card__title {
    color: #fde68a;
  }
  .spellbound-product-card__price {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }
</style>

<section class="spellbound-featured">
  <div class="spellbound-featured__inner">
    <div class="spellbound-featured__header">
      <h2 class="spellbound-featured__title">{{ section.settings.heading }}</h2>
      {% if section.settings.view_all_link != blank %}
        <a href="{{ section.settings.view_all_link }}" class="spellbound-featured__view-all">View All</a>
      {% endif %}
    </div>

    {%- assign collection = section.settings.collection -%}
    {% if collection != blank %}
      <div class="spellbound-featured__grid">
        {% for product in collections[collection].products limit: section.settings.max_products %}
          <a href="{{ product.url }}" class="spellbound-product-card">
            <div class="spellbound-product-card__media">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  srcset="{{ product.featured_image | image_url: width: 400 }} 400w, {{ product.featured_image | image_url: width: 600 }} 600w"
                  sizes="(min-width: 1024px) 25vw, (min-width: 768px) 50vw, 100vw"
                  alt="{{ product.title | escape }}"
                  class="spellbound-product-card__image"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                >
              {% endif %}
              <div class="spellbound-product-card__badges">
                {% if product.metafields.custom.element != blank %}
                  <span class="spellbound-product-card__badge">{{ product.metafields.custom.element }}</span>
                {% endif %}
                {% if product.metafields.custom.intention != blank %}
                  <span class="spellbound-product-card__badge spellbound-product-card__badge--amber">{{ product.metafields.custom.intention }}</span>
                {% endif %}
              </div>
            </div>
            <div class="spellbound-product-card__info">
              <h3 class="spellbound-product-card__title">{{ product.title }}</h3>
              <p class="spellbound-product-card__price">{{ product.price | money }}</p>
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="spellbound-featured__grid">
        {% for i in (1..4) %}
          <div class="spellbound-product-card">
            <div class="spellbound-product-card__media" style="background: #1a1a1a;"></div>
            <div class="spellbound-product-card__info">
              <h3 class="spellbound-product-card__title">Sample Product {{ i }}</h3>
              <p class="spellbound-product-card__price">$0.00</p>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Spellbound Products",
  "tag": "section",
  "class": "spellbound-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Manifestations"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View all link"
    }
  ],
  "presets": [
    {
      "name": "Spellbound Products"
    }
  ]
}
{% endschema %}
