{% comment %}
  Renders shared Totally Spellbound product-card badges.
  Shows sold-out status, ruling element and first intention.
  Values normalised via spellbound-metafield-value (handles list metafields).

  Accepts:
  - product: {Object} product to render badges for

  Usage:
  {% render 'spellbound-badges', product: product %}
{% endcomment %}

{%- if product != blank -%}
  {%- unless product.available -%}
    <span class="product-badges__badge product-badges__badge--rectangle spellbound-product-card__availability">
      {{ 'content.product_badge_sold_out' | t }}
    </span>
  {%- endunless -%}

  {%- capture element_value -%}{%- render 'spellbound-metafield-value', value: product.metafields.custom.element -%}{%- endcapture -%}
  {%- capture intention_value -%}{%- render 'spellbound-metafield-value', value: product.metafields.custom.intention -%}{%- endcapture -%}
  {%- assign element_first = element_value | split: ',' | first | strip -%}
  {%- assign intention_first = intention_value | split: ',' | first | strip -%}

  {%- if element_first != blank -%}
    {% render 'spellbound-sigil', label: element_first, kind: 'element' %}
  {%- endif -%}
  {%- if intention_first != blank -%}
    {% render 'spellbound-sigil', label: intention_first, kind: 'intention' %}
  {%- endif -%}
{%- endif -%}
